<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <uses-permission android:name="android.permission.VIBRATE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC"/>
    <!-- Biometric authentication for secure wallet access -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC"/>
    <uses-permission android:name="android.permission.USE_FINGERPRINT"/>
    <!-- WAKE_LOCK: keeps CPU alive during transaction confirmation polling (45s window) -->
    <uses-permission android:name="android.permission.WAKE_LOCK"/>
    <!-- RECEIVE_BOOT_COMPLETED: allows auto-restart if user had bot running before reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>
    <!-- REQUEST_IGNORE_BATTERY_OPTIMIZATIONS: prevents Android killing the foreground service -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"/>
    <!-- SCHEDULE_EXACT_ALARM: required for reliable service restart on Android 12+ -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"/>
    <!-- USE_EXACT_ALARM: backup for alarm scheduling (no permission dialog needed) -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM"/>
    <!-- External storage: persist AI learning data across app reinstalls -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="29"/>
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32"/>
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"/>

    <application
        android:name=".AATEApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name_override"
        android:supportsRtl="true"
        android:theme="@style/Theme.AATE"
        android:networkSecurityConfig="@xml/network_security_config"
        android:requestLegacyExternalStorage="true">

        <!-- Security Screen - First Entry Point (Before Splash) -->
        <activity
            android:name=".ui.SecurityActivity"
            android:exported="true"
            android:theme="@style/Theme.AATE.Splash"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- Splash Screen - After Security Auth -->
        <activity
            android:name=".ui.SplashActivity"
            android:exported="false"
            android:theme="@style/Theme.AATE.Splash"
            android:screenOrientation="portrait">
        </activity>

        <activity
            android:name=".ui.MainActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize|fontScale"
            android:windowSoftInputMode="adjustResize|stateHidden"
            android:screenOrientation="portrait">
        </activity>

        <activity android:name=".ui.AlertsActivity"  android:exported="false"/>
        <activity android:name=".ui.JournalActivity" android:exported="false"/>
        <activity android:name=".ui.ErrorLogActivity" android:exported="false"/>
        <activity android:name=".ui.MultiAssetActivity" android:exported="false" android:screenOrientation="portrait"/>
        <activity android:name=".ui.CollectiveBrainActivity" android:exported="false"/>
        <activity android:name=".ui.BehaviorActivity" android:exported="false" android:screenOrientation="portrait"/>
        <activity android:name=".ui.InsiderWalletsActivity" android:exported="false" android:screenOrientation="portrait"/>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"/>
        </provider>

        <activity android:name=".ui.CurrencyActivity"
            android:exported="false"
            android:label="Currency"/>

        <activity
            android:name=".ui.WalletActivity"
            android:exported="false"
            android:label="Wallet"
            android:windowSoftInputMode="adjustResize"/>

        <!-- Bot runs as a foreground service so Android doesn't kill it -->
        <service
            android:name=".engine.BotService"
            android:exported="false"
            android:foregroundServiceType="dataSync"/>

        <!-- Auto-restart bot after device reboot if it was running -->
        <receiver
            android:name=".engine.BootReceiver"
            android:exported="true"
            android:enabled="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED"/>
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED"/>
            </intent-filter>
        </receiver>

        <!-- Network security: allow specific cleartext RPC endpoints -->
        <meta-data
            android:name="android.security.net.config"
            android:resource="@xml/network_security_config"/>

            <activity android:name=".ui.BacktestActivity"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"/>
    </application>

</manifest>
