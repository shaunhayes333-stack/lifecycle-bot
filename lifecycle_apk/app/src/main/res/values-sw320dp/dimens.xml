<?xml version="1.0" encoding="utf-8"?>
<!-- Very small phones — 320dp (e.g. iPhone SE size, older compact phones) -->
<resources>
    <!-- Spacing - tighter for small screens -->
    <dimen name="screen_padding">8dp</dimen>
    <dimen name="card_padding">10dp</dimen>
    <dimen name="card_margin">8dp</dimen>
    <dimen name="card_margin_bottom">8dp</dimen>
    <dimen name="inner_gap">6dp</dimen>

    <!-- Top bar -->
    <dimen name="topbar_height">48dp</dimen>
    <dimen name="topbar_icon_size">28dp</dimen>

    <!-- Hero balance -->
    <dimen name="balance_text_size">24sp</dimen>
    <dimen name="balance_secondary_size">11sp</dimen>
    <dimen name="pnl_text_size">10sp</dimen>

    <!-- Token card -->
    <dimen name="token_name_size">13sp</dimen>
    <dimen name="token_phase_size">9sp</dimen>
    <dimen name="kpi_value_size">11sp</dimen>
    <dimen name="kpi_label_size">8sp</dimen>

    <!-- Score bars -->
    <dimen name="bar_height">3dp</dimen>
    <dimen name="bar_label_min_width">28dp</dimen>
    <dimen name="bar_val_width">20dp</dimen>

    <!-- Chart -->
    <dimen name="chart_height">100dp</dimen>

    <!-- Section headings -->
    <dimen name="section_title_size">11sp</dimen>

    <!-- Input fields -->
    <dimen name="input_height">38dp</dimen>
    <dimen name="input_text_size">12sp</dimen>
    <dimen name="input_padding_h">8dp</dimen>

    <!-- Bottom bar -->
    <dimen name="bottom_bar_button_height">44dp</dimen>
    <dimen name="bottom_bar_button_text">13sp</dimen>
    <dimen name="bottom_bar_padding_bottom">12dp</dimen>
    <dimen name="bottom_bar_padding_h">12dp</dimen>
    <dimen name="bottom_bar_padding_top">8dp</dimen>
    <dimen name="content_bottom_padding">72dp</dimen>

    <!-- Trade rows -->
    <dimen name="trade_row_text">10sp</dimen>
    <dimen name="trade_sub_text">8sp</dimen>

    <!-- Signal chip -->
    <dimen name="chip_text_size">8sp</dimen>
    <dimen name="chip_pad_h">6dp</dimen>
    <dimen name="chip_pad_v">3dp</dimen>

    <!-- Dot indicator -->
    <dimen name="dot_size">6dp</dimen>
    <dimen name="dot_margin">4dp</dimen>
    
    <!-- V5.6.10: Probation/watchlist card scaling -->
    <dimen name="card_logo_size">24dp</dimen>
    <dimen name="card_symbol_size">9sp</dimen>
    <dimen name="card_detail_size">7sp</dimen>
    <dimen name="card_badge_size">7sp</dimen>
</resources>
