<?xml version="1.0" encoding="utf-8"?>
<!-- Large logo background for wallet screen with premium glow -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="120dp"
                android:startColor="#2564D2D2"
                android:endColor="#00000000"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>
    <!-- Main background -->
    <item android:left="4dp" android:top="4dp" android:right="4dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#000000"/>
            <corners android:radius="20dp"/>
            <stroke android:width="2dp" android:color="#2A5555"/>
        </shape>
    </item>
</layer-list>
