<?xml version="1.0" encoding="utf-8"?>
<!-- Premium header gradient for AATE branding -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Subtle top accent line -->
    <item android:height="1dp" android:gravity="bottom">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="#0064D2D2"
                android:centerColor="#2064D2D2"
                android:endColor="#0064D2D2"/>
        </shape>
    </item>
    <!-- Main gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="180"
                android:startColor="#0A0C10"
                android:endColor="#0F1218"/>
        </shape>
    </item>
</layer-list>
