<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Subtle glow/shadow layer -->
    <item android:bottom="1dp" android:left="1dp" android:right="1dp" android:top="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#0D1117"/>
            <corners android:radius="14dp"/>
        </shape>
    </item>
    <!-- Main card -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="145"
                android:startColor="#12161F"
                android:endColor="#0D1117"/>
            <stroke android:width="1dp" android:color="#1E2A3A"/>
            <corners android:radius="14dp"/>
        </shape>
    </item>
</layer-list>
