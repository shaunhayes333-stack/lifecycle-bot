<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient android:type="linear" android:angle="90" android:startColor="#07101B" android:centerColor="#080B14" android:endColor="#07131D"/>
        </shape>
    </item>
    <item android:height="1dp" android:gravity="bottom">
        <shape android:shape="rectangle">
            <gradient android:type="linear" android:angle="0" android:startColor="#007DD3FC" android:centerColor="#5564D2D2" android:endColor="#0010B981"/>
        </shape>
    </item>
</layer-list>
