<?xml version="1.0" encoding="utf-8"?>
<!-- Premium action button with cyan accent -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Glow layer -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="80dp"
                android:centerY="1"
                android:startColor="#3064D2D2"
                android:endColor="#00000000"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>
    <!-- Main button -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#64D2D2"
                android:endColor="#4ECDC4"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>
</layer-list>
