<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="220dp"
                android:centerX="0.18"
                android:centerY="0.00"
                android:startColor="#554F46E5"
                android:centerColor="#224F46E5"
                android:endColor="#00000000"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#22293D"
                android:centerColor="#131827"
                android:endColor="#090D17"/>
            <stroke android:width="1dp" android:color="#385B6CFF"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>
    <item android:height="2dp" android:gravity="top">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="#0064D2D2"
                android:centerColor="#AA64D2D2"
                android:endColor="#00A78BFA"/>
            <corners android:topLeftRadius="24dp" android:topRightRadius="24dp"/>
        </shape>
    </item>
</layer-list>
