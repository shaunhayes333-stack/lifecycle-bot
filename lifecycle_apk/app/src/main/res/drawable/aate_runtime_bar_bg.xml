<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient android:type="linear" android:angle="90" android:startColor="#101827" android:centerColor="#080D16" android:endColor="#05070D"/>
            <stroke android:width="1dp" android:color="#1F2D45"/>
        </shape>
    </item>
    <item android:height="1dp" android:gravity="top">
        <shape android:shape="rectangle">
            <solid android:color="#334B5563"/>
        </shape>
    </item>
</layer-list>
