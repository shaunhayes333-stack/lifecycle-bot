<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#111A2B"
                android:centerColor="#0A111D"
                android:endColor="#050A12"/>
            <stroke android:width="1dp" android:color="#284064"/>
            <corners android:radius="18dp"/>
        </shape>
    </item>
    <item android:height="2dp" android:gravity="top">
        <shape android:shape="rectangle">
            <gradient android:type="linear" android:angle="0" android:startColor="#007DD3FC" android:centerColor="#AA10B981" android:endColor="#00A78BFA"/>
            <corners android:topLeftRadius="18dp" android:topRightRadius="18dp"/>
        </shape>
    </item>
</layer-list>
