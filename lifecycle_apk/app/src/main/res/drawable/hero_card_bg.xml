<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="200dp"
                android:centerX="0.5"
                android:centerY="0"
                android:startColor="#1564D2D2"
                android:endColor="#00000000"/>
            <corners android:radius="18dp"/>
        </shape>
    </item>
    <!-- Main card -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#141824"
                android:centerColor="#10141C"
                android:endColor="#0C1018"/>
            <stroke android:width="1dp" android:color="#1E2836"/>
            <corners android:radius="18dp"/>
        </shape>
    </item>
</layer-list>
