<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="220dp"
                android:centerX="0.15"
                android:centerY="0.0"
                android:startColor="#203B82F6"
                android:centerColor="#111C2F"
                android:endColor="#07101B"/>
            <stroke android:width="1dp" android:color="#2F415F"/>
            <corners android:radius="18dp"/>
        </shape>
    </item>
    <item android:height="1dp" android:gravity="top">
        <shape android:shape="rectangle">
            <gradient android:type="linear" android:angle="0" android:startColor="#0064D2D2" android:centerColor="#557DD3FC" android:endColor="#0010B981"/>
            <corners android:topLeftRadius="18dp" android:topRightRadius="18dp"/>
        </shape>
    </item>
</layer-list>
