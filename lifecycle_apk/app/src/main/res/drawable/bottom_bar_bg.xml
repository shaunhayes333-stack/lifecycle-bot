<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Top accent line -->
    <item android:height="1dp" android:gravity="top">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="#0064D2D2"
                android:centerColor="#3064D2D2"
                android:endColor="#0064D2D2"/>
        </shape>
    </item>
    <!-- Main background -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="90"
                android:startColor="#0A0A0F"
                android:endColor="#0F1218"/>
            <corners android:topLeftRadius="24dp" android:topRightRadius="24dp"/>
        </shape>
    </item>
</layer-list>
