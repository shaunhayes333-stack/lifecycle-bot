<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Glow halo -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="999dp"/>
            <stroke android:width="2dp" android:color="#66A78BFA"/>
            <solid android:color="#00000000"/>
        </shape>
    </item>
    <!-- Inner solid neon -->
    <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="999dp"/>
            <gradient
                android:startColor="#FFA78BFA"
                android:endColor="#FF7C3AED"
                android:type="linear"
                android:angle="135"/>
            <stroke android:width="0dp" android:color="#00000000"/>
        </shape>
    </item>
</layer-list>
