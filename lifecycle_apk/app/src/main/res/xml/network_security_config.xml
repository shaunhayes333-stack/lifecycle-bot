<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- V5.0.3770: Android trust-source repair for Solana RPC / Helius / Jupiter / Pump endpoints.
         Use platform + user CAs so devices with updated user-installed roots or OEM CA drift do not
         fail wallet proof with CertPathValidatorException: Trust anchor not found. No cleartext. -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">helius-rpc.com</domain>
        <domain includeSubdomains="true">helius.xyz</domain>
        <domain includeSubdomains="true">jup.ag</domain>
        <domain includeSubdomains="true">jup.io</domain>
        <domain includeSubdomains="true">pump.fun</domain>
        <domain includeSubdomains="true">solana.com</domain>
        <domain includeSubdomains="true">ankr.com</domain>
        <domain includeSubdomains="true">alchemy.com</domain>
        <domain includeSubdomains="true">public-rpc.com</domain>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </domain-config>
</network-security-config>
