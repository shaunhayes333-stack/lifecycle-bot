<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- ── TOP BAR ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/topbar_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/screen_padding"
        android:paddingEnd="@dimen/screen_padding"
        android:background="#0A0A0F">

        <TextView
            android:id="@+id/btnWatchlistBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:paddingEnd="12dp"
            android:clickable="true"
            android:focusable="true"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Watchlist"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <!-- Live dot -->
                <View
                    android:layout_width="5dp"
                    android:layout_height="5dp"
                    android:layout_marginStart="6dp"
                    android:layout_marginBottom="1dp"
                    android:background="@drawable/dot_green"/>

            </LinearLayout>

            <TextView
                android:id="@+id/tvWatchlistStats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 items · 0 alerts"
                android:textColor="#4B5563"
                android:textSize="9sp"
                android:fontFamily="monospace"/>

        </LinearLayout>

        <!-- Scan button -->
        <TextView
            android:id="@+id/btnRefreshWatchlist"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:gravity="center"
            android:text="↻ Scan"
            android:textColor="#14F195"
            android:textSize="11sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/pill_bg"
            android:clickable="true"
            android:focusable="true"/>

        <!-- Add button -->
        <TextView
            android:id="@+id/btnAddSymbol"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:gravity="center"
            android:text="+ Add"
            android:textColor="#000000"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/pill_bg_green"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

    <!-- ── TABS ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:paddingStart="@dimen/screen_padding"
        android:paddingEnd="@dimen/screen_padding"
        android:background="#0A0A0F">

        <TextView
            android:id="@+id/tabWatchlist"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="WATCHLIST"
            android:textColor="#14F195"
            android:textSize="10sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:background="@drawable/tab_active_bg"
            android:layout_marginEnd="3dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/tabActiveAlerts"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="ALERTS"
            android:textColor="#4B5563"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:background="@drawable/tab_inactive_bg"
            android:layout_marginEnd="3dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/tabTriggered"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="TRIGGERED"
            android:textColor="#4B5563"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:background="@drawable/tab_inactive_bg"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

    <!-- Accent line under tabs -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#111827"/>

    <!-- Loading bar -->
    <ProgressBar
        android:id="@+id/progressWatchlist"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:progressTint="#14F195"
        android:indeterminate="true"
        android:visibility="gone"/>

    <!-- ── CONTENT LIST ── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:id="@+id/llWatchlistContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/screen_padding"
            android:paddingEnd="@dimen/screen_padding"
            android:paddingTop="@dimen/inner_gap"
            android:paddingBottom="@dimen/content_bottom_padding"/>

    </ScrollView>

</LinearLayout>
