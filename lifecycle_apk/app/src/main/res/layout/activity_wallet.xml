<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- ── TOP BAR ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="6dp"
        android:background="#0A0A0F">

        <Button
            android:id="@+id/btnBackToBot"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="←"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:backgroundTint="@android:color/transparent"
            android:paddingStart="0dp"
            android:paddingEnd="12dp"
            android:minWidth="0dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Wallet"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tvConnectionStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● Disconnected"
                android:textColor="#6B7280"
                android:textSize="9sp"
                android:fontFamily="monospace"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnRefreshBalance"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="↻"
            android:textSize="16sp"
            android:textColor="#9945FF"
            android:backgroundTint="#111720"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:minWidth="0dp"/>
    </LinearLayout>

    <!-- ── HERO BALANCE ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SOL BALANCE"
            android:textColor="#6B7280"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:fontFamily="monospace"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom">
            <TextView
                android:id="@+id/tvSolBalance"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#00FF88"
                android:textSize="28sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="14sp"
                android:autoSizeMaxTextSize="28sp"
                android:autoSizeStepGranularity="1sp"/>
            <TextView
                android:id="@+id/tvUsdBalance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#6B7280"
                android:textSize="13sp"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="4dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="2dp">
            <TextView
                android:id="@+id/tvSolPrice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="SOL $—"
                android:textColor="#4A5E70"
                android:textSize="10sp"
                android:fontFamily="monospace"/>
            <TextView
                android:id="@+id/tvLastRefreshed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#4A5E70"
                android:textSize="10sp"
                android:fontFamily="monospace"/>
        </LinearLayout>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#1F2937"/>

    <!-- ── SCROLLABLE CONTENT ── -->
    <ScrollView
        android:id="@+id/walletScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false">

        <LinearLayout
            android:id="@+id/walletContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="24dp">

            <!-- ══ CONNECTION SECTION ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/section_card_bg"
                android:padding="14dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WALLET CONNECTION"
                    android:textColor="#6B7280"
                    android:textSize="10sp"
                    android:letterSpacing="0.10"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="10dp"/>

                <!-- Connected -->
                <LinearLayout
                    android:id="@+id/layoutConnected"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PUBLIC KEY"
                        android:textColor="#6B7280"
                        android:textSize="9sp"
                        android:fontFamily="monospace"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:id="@+id/tvPublicKey"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#DCE8F0"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:layout_marginBottom="12dp"
                        android:textIsSelectable="true"/>
                    <Button
                        android:id="@+id/btnDisconnect"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:text="DISCONNECT WALLET"
                        android:backgroundTint="#331111"
                        android:textColor="#FF4444"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"/>
                </LinearLayout>

                <!-- Disconnected -->
                <LinearLayout
                    android:id="@+id/layoutDisconnected"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="visible">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PRIVATE KEY (base58)"
                        android:textColor="#6B7280"
                        android:textSize="9sp"
                        android:fontFamily="monospace"
                        android:layout_marginBottom="6dp"/>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">
                        <EditText
                            android:id="@+id/etPrivKeyInput"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="44dp"
                            android:hint="Enter base58 private key…"
                            android:hintTextColor="#4A5E70"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:fontFamily="monospace"
                            android:inputType="textPassword"
                            android:background="@drawable/input_bg"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"/>
                        <Button
                            android:id="@+id/btnShowHideKey"
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:text="Show"
                            android:textSize="11sp"
                            android:backgroundTint="#111720"
                            android:textColor="#6B7280"
                            android:layout_marginStart="8dp"
                            android:minWidth="0dp"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RPC URL (optional)"
                        android:textColor="#6B7280"
                        android:textSize="9sp"
                        android:fontFamily="monospace"
                        android:layout_marginBottom="6dp"/>
                    <EditText
                        android:id="@+id/etRpcUrl"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:hint="https://api.mainnet-beta.solana.com"
                        android:hintTextColor="#4A5E70"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:inputType="textUri"
                        android:singleLine="true"
                        android:background="@drawable/input_bg"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:layout_marginBottom="6dp"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="💡 Leave empty to auto-connect via public RPCs"
                        android:textColor="#4A5E70"
                        android:textSize="10sp"
                        android:layout_marginBottom="10dp"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="⚠ Use a dedicated burner wallet only. Never your main wallet."
                        android:textColor="#FFB700"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:layout_marginBottom="14dp"/>

                    <Button
                        android:id="@+id/btnChangeKey"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Change Key"
                        android:textSize="11sp"
                        android:textColor="#9945FF"
                        android:backgroundTint="#111720"
                        android:visibility="gone"
                        android:layout_marginBottom="10dp"
                        android:minWidth="0dp"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"/>

                    <Button
                        android:id="@+id/btnConnect"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:text="CONNECT WALLET"
                        android:backgroundTint="#00E5A0"
                        android:textColor="#000000"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ══ LOGO ══ -->
            <ImageView
                android:id="@+id/ivWalletLogo"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:src="@drawable/logo"
                android:scaleType="centerCrop"
                android:background="@drawable/logo_bg_large"
                android:padding="4dp"
                android:contentDescription="AATE Logo"/>

            <!-- ══ P&L SUMMARY ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/section_card_bg"
                android:padding="14dp"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="PERFORMANCE"
                        android:textColor="#6B7280"
                        android:textSize="10sp"
                        android:letterSpacing="0.10"
                        android:fontFamily="monospace"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TOTAL P&amp;L"
                            android:textColor="#6B7280"
                            android:textSize="9sp"
                            android:fontFamily="monospace"/>
                        <TextView
                            android:id="@+id/tvTotalPnl"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="#00FF88"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RETURN"
                            android:textColor="#6B7280"
                            android:textSize="9sp"
                            android:fontFamily="monospace"/>
                        <TextView
                            android:id="@+id/tvTotalPnlPct"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="#00FF88"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TRADES"
                            android:textColor="#6B7280"
                            android:textSize="9sp"
                            android:fontFamily="monospace"/>
                        <TextView
                            android:id="@+id/tvTotalTrades"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="WIN RATE"
                            android:textColor="#6B7280"
                            android:textSize="9sp"
                            android:fontFamily="monospace"/>
                        <TextView
                            android:id="@+id/tvWinRate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- P&L Chart -->
                <com.lifecyclebot.ui.PnlChartView
                    android:id="@+id/pnlChart"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginBottom="8dp"/>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#1F2937" android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:id="@+id/tvBestTrade"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Best: —"
                        android:textColor="#00FF88"
                        android:textSize="11sp"
                        android:fontFamily="monospace"/>
                    <TextView
                        android:id="@+id/tvWorstTrade"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Worst: —"
                        android:textColor="#FF4444"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:gravity="end"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ══ WITHDRAW FROM TREASURY ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/section_card_bg"
                android:padding="14dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WITHDRAW FROM TREASURY"
                    android:textColor="#6B7280"
                    android:textSize="10sp"
                    android:letterSpacing="0.10"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="10dp"/>

                <!-- Treasury balance row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TREASURY LOCKED"
                            android:textColor="#6B7280"
                            android:textSize="9sp"
                            android:fontFamily="monospace"/>
                        <TextView
                            android:id="@+id/tvWithdrawTreasuryBal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.0000◎"
                            android:textColor="#00FF88"
                            android:textSize="14sp"
                            android:fontFamily="monospace"
                            android:textStyle="bold"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TRADEABLE"
                            android:textColor="#6B7280"
                            android:textSize="9sp"
                            android:fontFamily="monospace"/>
                        <TextView
                            android:id="@+id/tvWithdrawTradeable"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.0000◎"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:fontFamily="monospace"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#1F2937" android:layout_marginBottom="10dp"/>

                <!-- Percentage selector -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AMOUNT"
                        android:textColor="#6B7280"
                        android:textSize="9sp"
                        android:fontFamily="monospace"/>
                    <TextView
                        android:id="@+id/tvWithdrawPct"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="50%"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:fontFamily="monospace"
                        android:textStyle="bold"
                        android:gravity="end"/>
                    <TextView
                        android:id="@+id/tvWithdrawSolAmt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#6B7280"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>

                <!-- Percentage quick-select -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">
                    <Button android:id="@+id/btnWith25"
                        android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
                        android:text="25%" android:textSize="12sp" android:textColor="#9CA3AF"
                        android:backgroundTint="#111720" android:layout_marginEnd="4dp"
                        android:fontFamily="monospace"/>
                    <Button android:id="@+id/btnWith50"
                        android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
                        android:text="50%" android:textSize="12sp" android:textColor="#9CA3AF"
                        android:backgroundTint="#111720" android:layout_marginEnd="4dp"
                        android:fontFamily="monospace"/>
                    <Button android:id="@+id/btnWith75"
                        android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
                        android:text="75%" android:textSize="12sp" android:textColor="#9CA3AF"
                        android:backgroundTint="#111720" android:layout_marginEnd="4dp"
                        android:fontFamily="monospace"/>
                    <Button android:id="@+id/btnWith100"
                        android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
                        android:text="100%" android:textSize="12sp" android:textColor="#FF4444"
                        android:backgroundTint="#2A0A0A"
                        android:fontFamily="monospace"/>
                </LinearLayout>

                <!-- SeekBar -->
                <SeekBar android:id="@+id/seekWithdrawPct"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:max="100" android:progress="50"
                    android:thumbTint="#9945FF" android:progressTint="#9945FF"
                    android:progressBackgroundTint="#1F2937"
                    android:layout_marginBottom="14dp"/>

                <!-- Destination address -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DESTINATION ADDRESS"
                    android:textColor="#6B7280"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="6dp"/>
                <EditText android:id="@+id/etWithdrawDest"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:hint="Leave blank to send to your own wallet"
                    android:hintTextColor="#4A5E70"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:inputType="text"
                    android:maxLines="1"
                    android:background="@drawable/input_bg"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginBottom="8dp"/>

                <!-- Warning for 100% -->
                <TextView android:id="@+id/tvWithdrawWarning"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="⚠ You are withdrawing 100% of the treasury. The bot will have no locked profit reserve."
                    android:textColor="#FFB700" android:textSize="11sp" android:fontFamily="monospace"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone"/>

                <!-- Confirm -->
                <Button android:id="@+id/btnWithdrawConfirm"
                    android:layout_width="match_parent" android:layout_height="44dp"
                    android:text="WITHDRAW"
                    android:backgroundTint="#9945FF" android:textColor="#FFFFFF"
                    android:textStyle="bold" android:fontFamily="monospace"/>

                <TextView android:id="@+id/tvWithdrawStatus"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="" android:textColor="#4A5E70"
                    android:textSize="12sp" android:fontFamily="monospace"
                    android:layout_marginTop="8dp"
                    android:minLines="2"/>
            </LinearLayout>

            <!-- ══ SECURITY NOTE ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/section_card_bg"
                android:padding="14dp"
                android:layout_marginBottom="24dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔒"
                    android:textSize="18sp"
                    android:layout_marginEnd="10dp"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Your private key is stored encrypted on-device only. It is never transmitted or logged."
                    android:textColor="#6B7280"
                    android:textSize="11sp"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
