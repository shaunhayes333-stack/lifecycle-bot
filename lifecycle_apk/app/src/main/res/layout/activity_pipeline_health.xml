<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/aate_screen_bg"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- TOP BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="8dp"
        android:background="@drawable/aate_screen_bg">

        <ImageButton
            android:id="@+id/backButton"
            android:stateListAnimator="@null"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:background="@android:color/transparent"
            android:padding="8dp"
            android:contentDescription="Back"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Pipeline Health"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="4dp"/>

        <TextView
            android:id="@+id/anrBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ANR: 0"
            android:textColor="#10B981"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="#10B98122"/>
    </LinearLayout>

    <!-- ACTION ROW -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="4dp"
        android:paddingBottom="8dp">

        <Button
            android:id="@+id/copyButton"
            android:stateListAnimator="@null"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="Copy to Clipboard"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:background="#1F2937"/>

        <Button
            android:id="@+id/refreshButton"
            android:stateListAnimator="@null"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="Refresh"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:background="#1F2937"/>

        <Button
            android:id="@+id/resetButton"
            android:stateListAnimator="@null"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Reset"
            android:textSize="13sp"
            android:textColor="#FCA5A5"
            android:background="#1F2937"/>
    </LinearLayout>

    <!-- HEADLINE STATS GRID -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="6dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:padding="10dp"
            android:orientation="vertical"
            android:background="@drawable/aate_debug_card_bg">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LOOP"
                android:textColor="#7C8190"
                android:textSize="11sp"/>
            <TextView
                android:id="@+id/statLoop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:padding="10dp"
            android:orientation="vertical"
            android:background="@drawable/aate_debug_card_bg">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EXEC"
                android:textColor="#7C8190"
                android:textSize="11sp"/>
            <TextView
                android:id="@+id/statExec"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#10B981"
                android:textSize="20sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:padding="10dp"
            android:orientation="vertical"
            android:background="@drawable/aate_debug_card_bg">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="JRNL"
                android:textColor="#7C8190"
                android:textSize="11sp"/>
            <TextView
                android:id="@+id/statJrnl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#3B82F6"
                android:textSize="20sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:padding="10dp"
            android:orientation="vertical"
            android:background="@drawable/aate_debug_card_bg">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MAX FRAME"
                android:textColor="#7C8190"
                android:textSize="11sp"/>
            <TextView
                android:id="@+id/statMaxFrame"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 ms"
                android:textColor="#F59E0B"
                android:textSize="18sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>


    <!-- SECTION PAGER: full report stays available without one giant TextView layout -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="4dp"
        android:paddingBottom="6dp">

        <Button
            android:id="@+id/prevSectionButton"
            android:stateListAnimator="@null"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="◀"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:background="#1F2937"/>

        <TextView
            android:id="@+id/sectionLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:text="Section 1/1"
            android:textColor="#D1D5DB"
            android:textSize="12sp"
            android:typeface="monospace"/>

        <Button
            android:id="@+id/nextSectionButton"
            android:stateListAnimator="@null"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▶"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:background="#1F2937"/>
    </LinearLayout>

    <!-- BODY: monospace dump in scroll view -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:padding="6dp">

        <TextView
            android:id="@+id/dumpText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="10dp"
            android:typeface="monospace"
            android:textSize="11sp"
            android:textColor="#D1D5DB"
            android:background="@drawable/aate_debug_card_bg"
            android:textIsSelectable="true"
            android:fontFamily="monospace"/>
    </ScrollView>

    <!-- FOOTER NOTE -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:text="Full report is sectioned on-screen to prevent UI choke. Use ◀/▶ to view every section; Copy exports the exact full dump."
        android:textColor="#6B7280"
        android:textSize="11sp"
        android:gravity="center"/>

</LinearLayout>
