<?xml version="1.0" encoding="utf-8"?>
<!--
  V5.9.350 — Persona Studio
  Trait sliders · Milestone timeline · Chat replay · Custom sounds.
  Reads/writes PersonalityMemoryStore and copies user-picked MP3s into
  filesDir/custom_sounds/ which SoundManager checks first.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/personaStudioRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#07090E"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🧠 Persona Studio"
                android:textColor="#00FF88"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <TextView
                android:id="@+id/tvActivePersona"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="aate"
                android:textColor="#9945FF"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:background="@drawable/pill_bg"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"/>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tune how the bot feels, remember its journey, replay its voice."
            android:textColor="#6B7280"
            android:textSize="11sp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp"/>

        <!-- ═════════════════ TRAITS ═════════════════ -->
        <LinearLayout
            android:id="@+id/cardTraits"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/section_card_bg"
            android:padding="12dp"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎛  Traits"
                    android:textColor="#00FF88"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"/>
                <TextView
                    android:id="@+id/tvTraitsSummary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="balanced"
                    android:textColor="#9CA3AF"
                    android:textSize="10sp"
                    android:fontFamily="monospace"/>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sliders drift automatically from trade outcomes. Drag to override manually."
                android:textColor="#6B7280"
                android:textSize="10sp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:id="@+id/llTraitRows"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

            <TextView
                android:id="@+id/btnResetTraits"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔄 Reset traits to neutral"
                android:textColor="#F59E0B"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:background="@drawable/pill_bg"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:layout_marginTop="10dp"
                android:layout_gravity="end"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <!-- ═════════════════ MILESTONES ═════════════════ -->
        <LinearLayout
            android:id="@+id/cardMilestones"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/section_card_bg"
            android:padding="12dp"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📜  Milestone Timeline"
                    android:textColor="#00FF88"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"/>
                <TextView
                    android:id="@+id/tvMilestoneCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#9CA3AF"
                    android:textSize="10sp"
                    android:fontFamily="monospace"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llMilestones"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/tvMilestonesEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No milestones yet — the bot hasn't lived enough. Trade it in."
                android:textColor="#6B7280"
                android:textSize="11sp"
                android:gravity="center"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- ═════════════════ CHAT REPLAY ═════════════════ -->
        <LinearLayout
            android:id="@+id/cardChat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/section_card_bg"
            android:padding="12dp"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💬  Chat Replay"
                    android:textColor="#00FF88"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"/>
                <TextView
                    android:id="@+id/tvChatCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 turns"
                    android:textColor="#9CA3AF"
                    android:textSize="10sp"
                    android:fontFamily="monospace"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llChat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/tvChatEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No chat yet. Start a conversation in the LLM Desk."
                android:textColor="#6B7280"
                android:textSize="11sp"
                android:gravity="center"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- ═════════════════ CUSTOM SOUNDS ═════════════════ -->
        <LinearLayout
            android:id="@+id/cardSounds"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/section_card_bg"
            android:padding="12dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎵  Custom Sounds"
                android:textColor="#00FF88"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tap any row to pick an MP3 from your device. It replaces the built-in sound for that event."
                android:textColor="#6B7280"
                android:textSize="10sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:id="@+id/rowSoundWoohoo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="8dp"
                android:background="@drawable/pill_bg"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="6dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🎉 Buy (woohoo)"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"/>
                <TextView
                    android:id="@+id/tvSoundWoohooStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="default"
                    android:textColor="#6B7280"
                    android:textSize="10sp"
                    android:fontFamily="monospace"/>
                <TextView
                    android:id="@+id/btnSoundWoohooReset"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✕"
                    android:textColor="#EF4444"
                    android:textSize="12sp"
                    android:paddingStart="10dp"
                    android:paddingEnd="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:visibility="gone"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowSoundAwesome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="8dp"
                android:background="@drawable/pill_bg"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="6dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🛡️ Block (awesome)"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"/>
                <TextView
                    android:id="@+id/tvSoundAwesomeStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="default"
                    android:textColor="#6B7280"
                    android:textSize="10sp"
                    android:fontFamily="monospace"/>
                <TextView
                    android:id="@+id/btnSoundAwesomeReset"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✕"
                    android:textColor="#EF4444"
                    android:textSize="12sp"
                    android:paddingStart="10dp"
                    android:paddingEnd="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:visibility="gone"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowSoundAplus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="8dp"
                android:background="@drawable/pill_bg"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="⭐ A+ Setup Alert"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"/>
                <TextView
                    android:id="@+id/tvSoundAplusStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="default"
                    android:textColor="#6B7280"
                    android:textSize="10sp"
                    android:fontFamily="monospace"/>
                <TextView
                    android:id="@+id/btnSoundAplusReset"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✕"
                    android:textColor="#EF4444"
                    android:textSize="12sp"
                    android:paddingStart="10dp"
                    android:paddingEnd="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:visibility="gone"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
