<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="false">

    <!-- Subtle glow effect behind logo (MUST BE FIRST - bottom layer) -->
    <View
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:layout_gravity="center"
        android:background="@drawable/splash_glow"
        android:alpha="0.3"/>

    <!-- Centered content (ON TOP of glow) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:elevation="4dp">

        <!-- AATE Logo -->
        <ImageView
            android:id="@+id/ivSplashLogo"
            android:layout_width="280dp"
            android:layout_height="280dp"
            android:src="@drawable/logo"
            android:scaleType="fitCenter"
            android:contentDescription="AATE Logo"/>

        <!-- Tagline -->
        <TextView
            android:id="@+id/tvSplashTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Autonomous Algorithmic Trading Engine"
            android:textColor="#6B7280"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.05"
            android:visibility="invisible"/>

    </LinearLayout>

    <!-- Version at bottom -->
    <TextView
        android:id="@+id/tvSplashVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="80dp"
        android:text="v4.0.0"
        android:textColor="#6B7280"
        android:textSize="14sp"
        android:fontFamily="monospace"
        android:visibility="invisible"/>

    <!-- Copyright and Trademark notice at very bottom -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvSplashTrademark"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AATE® is a registered trademark"
            android:textColor="#374151"
            android:textSize="10sp"
            android:fontFamily="monospace"/>

        <TextView
            android:id="@+id/tvSplashCopyright"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="© 2024-2026 Lifecycle Technologies. All rights reserved."
            android:textColor="#374151"
            android:textSize="9sp"
            android:fontFamily="monospace"/>

    </LinearLayout>

</FrameLayout>
