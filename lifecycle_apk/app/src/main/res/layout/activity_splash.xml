<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="false">

    <!-- Neural pathway particles container (animated in code) -->
    <FrameLayout
        android:id="@+id/layoutParticles"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Glow bloom behind logo — deep purple, not teal -->
    <View
        android:id="@+id/viewGlow"
        android:layout_width="340dp"
        android:layout_height="340dp"
        android:layout_gravity="center"
        android:background="@drawable/splash_glow"
        android:alpha="0.35"/>

    <!-- Centred content stack -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:elevation="4dp">

        <!-- AATE Logo -->
        <ImageView
            android:id="@+id/ivSplashLogo"
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:src="@drawable/logo"
            android:scaleType="fitCenter"
            android:contentDescription="AATE Logo"/>

        <!-- Boot tagline — animated in from invisible -->
        <TextView
            android:id="@+id/tvSplashTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="AUTONOMOUS ALGORITHMIC TRADING ENGINE"
            android:textColor="#9945FF"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.12"
            android:visibility="invisible"/>

    </LinearLayout>

    <!-- Version — boot build string, shown after neural init -->
    <TextView
        android:id="@+id/tvSplashVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="88dp"
        android:text=""
        android:textColor="#14F195"
        android:textSize="13sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:letterSpacing="0.06"
        android:visibility="invisible"/>

    <!-- Legal — low contrast, stays out of the way -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingBottom="14dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <TextView
            android:id="@+id/tvSplashTrademark"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AATE® is a registered trademark"
            android:textColor="#1F2937"
            android:textSize="9sp"
            android:fontFamily="monospace"/>

        <TextView
            android:id="@+id/tvSplashCopyright"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="© 2024-2026 Lifecycle Technologies. All rights reserved."
            android:textColor="#1F2937"
            android:textSize="8sp"
            android:fontFamily="monospace"/>

    </LinearLayout>

</FrameLayout>
