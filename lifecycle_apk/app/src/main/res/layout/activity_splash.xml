<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="false">

    <!-- Centered content -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center">

        <!-- AATE Logo -->
        <ImageView
            android:id="@+id/ivSplashLogo"
            android:layout_width="280dp"
            android:layout_height="280dp"
            android:src="@drawable/logo"
            android:scaleType="fitCenter"
            android:alpha="0"
            android:contentDescription="AATE Logo"/>

        <!-- Tagline -->
        <TextView
            android:id="@+id/tvSplashTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Autonomous Algorithmic Trading Engine"
            android:textColor="#6B7280"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.05"
            android:visibility="invisible"/>

    </LinearLayout>

    <!-- Version at bottom -->
    <TextView
        android:id="@+id/tvSplashVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="48dp"
        android:text="v1.2.0"
        android:textColor="#374151"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:visibility="invisible"/>

    <!-- Subtle glow effect behind logo -->
    <View
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:layout_gravity="center"
        android:background="@drawable/splash_glow"
        android:alpha="0.3"/>

</FrameLayout>
