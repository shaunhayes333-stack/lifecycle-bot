<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="false">

    <!-- Neural pathway particles container (animated in code) -->
    <FrameLayout
        android:id="@+id/layoutParticles"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- V5.2: Animated Brain Wave Background -->
    <com.lifecyclebot.ui.AnimatedBrainLogoView
        android:id="@+id/viewBrainWaves"
        android:layout_width="400dp"
        android:layout_height="400dp"
        android:layout_gravity="center"/>

    <!-- Subtle glow effect behind logo -->
    <View
        android:id="@+id/viewGlow"
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:layout_gravity="center"
        android:background="@drawable/splash_glow"
        android:alpha="0.3"/>

    <!-- Centered content -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:elevation="4dp">

        <!-- AATE Logo - elevated above brain waves -->
        <ImageView
            android:id="@+id/ivSplashLogo"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:src="@drawable/logo"
            android:scaleType="fitCenter"
            android:elevation="8dp"
            android:contentDescription="AATE Logo"/>

        <!-- Tagline -->
        <TextView
            android:id="@+id/tvSplashTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Autonomous Algorithmic Trading Engine"
            android:textColor="#64D2D2"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.05"
            android:visibility="invisible"/>

    </LinearLayout>

    <!-- Version at bottom (set from BuildConfig at runtime) -->
    <TextView
        android:id="@+id/tvSplashVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="80dp"
        android:text=""
        android:textColor="#64D2D2"
        android:textSize="16sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:visibility="invisible"/>

    <!-- Copyright and Trademark notice at very bottom -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvSplashTrademark"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AATE® is a registered trademark"
            android:textColor="#374151"
            android:textSize="10sp"
            android:fontFamily="monospace"/>

        <TextView
            android:id="@+id/tvSplashCopyright"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="© 2024-2026 Lifecycle Technologies. All rights reserved."
            android:textColor="#374151"
            android:textSize="9sp"
            android:fontFamily="monospace"/>

    </LinearLayout>

</FrameLayout>
