<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- ── TOP BAR ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/screen_padding"
        android:paddingEnd="@dimen/screen_padding"
        android:paddingTop="10dp"
        android:paddingBottom="8dp"
        android:background="#0A0A0F">

        <TextView
            android:id="@+id/btnJournalBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:paddingEnd="12dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Trade Journal"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <TextView android:id="@+id/btnRestoreStats"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Restore" android:textColor="#10B981" android:textSize="12sp"
            android:paddingEnd="12dp" android:clickable="true" android:focusable="true"/>
        <TextView android:id="@+id/btnExportCsv"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Export" android:textColor="#9945FF" android:textSize="12sp"
            android:paddingEnd="12dp" android:clickable="true" android:focusable="true"/>
        <TextView android:id="@+id/btnClearJournal"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Clear" android:textColor="#EF4444" android:textSize="12sp"
            android:clickable="true" android:focusable="true"/>
    </LinearLayout>

    <!-- Stats summary bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="@dimen/screen_padding"
        android:paddingEnd="@dimen/screen_padding"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:background="@drawable/section_card_bg">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="TOTAL P&amp;L" android:textColor="#6B7280"
                android:textSize="9sp" android:fontFamily="monospace"/>
            <TextView android:id="@+id/tvJournalPnl"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="—" android:textColor="#10B981"
                android:textSize="@dimen/section_title_size" android:fontFamily="monospace"
                android:textStyle="bold"/>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="WIN RATE" android:textColor="#6B7280"
                android:textSize="9sp" android:fontFamily="monospace"/>
            <TextView android:id="@+id/tvJournalWinRate"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="—" android:textColor="#FFFFFF"
                android:textSize="@dimen/section_title_size" android:fontFamily="monospace"
                android:textStyle="bold"/>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="TRADES" android:textColor="#6B7280"
                android:textSize="9sp" android:fontFamily="monospace"/>
            <TextView android:id="@+id/tvJournalCount"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0" android:textColor="#FFFFFF"
                android:textSize="@dimen/section_title_size" android:fontFamily="monospace"
                android:textStyle="bold"/>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="AVG WIN" android:textColor="#6B7280"
                android:textSize="9sp" android:fontFamily="monospace"/>
            <TextView android:id="@+id/tvJournalAvgWin"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="—" android:textColor="#10B981"
                android:textSize="@dimen/section_title_size" android:fontFamily="monospace"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#1F2937"/>

    <!-- Trade list -->
    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:id="@+id/llJournalTrades"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/screen_padding"
            android:paddingEnd="@dimen/screen_padding"
            android:paddingTop="8dp"
            android:paddingBottom="32dp"/>
    </ScrollView>
</LinearLayout>
