<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A0F"
    android:fitsSystemWindows="true">

    <!-- ── TOP BAR ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/topbar_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/screen_padding"
        android:paddingEnd="@dimen/screen_padding"
        android:background="#0A0A0F">

        <TextView
            android:id="@+id/btnBrainBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:paddingEnd="12dp"
            android:clickable="true"
            android:focusable="true"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Collective Memory"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvSyncStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Checking…"
                android:textColor="#4B5563"
                android:textSize="9sp"
                android:fontFamily="monospace"/>

        </LinearLayout>

        <!-- Data source badge -->
        <TextView
            android:id="@+id/tvBrainDataSource"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:gravity="center"
            android:text="LOCAL"
            android:textColor="#9945FF"
            android:textSize="9sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:background="@drawable/pill_bg"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:layout_marginEnd="6dp"/>

        <!-- Sync now -->
        <TextView
            android:id="@+id/btnForceSync"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:gravity="center"
            android:text="↻ Sync"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:background="@drawable/pill_bg_green"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

    <!-- Accent divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#111827"/>

    <!-- ── SCROLLABLE CONTENT ── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/screen_padding"
            android:paddingEnd="@dimen/screen_padding"
            android:paddingTop="@dimen/card_margin"
            android:paddingBottom="@dimen/content_bottom_padding">

            <!-- ── BRAIN ANIMATION ── -->
            <com.lifecyclebot.ui.AnimatedBrainView
                android:id="@+id/brainView"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_gravity="center"
                android:layout_marginBottom="@dimen/card_margin"/>

            <!-- ── KEY STATS ROW ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/inner_gap">

                <!-- Total Trades -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/section_card_bg"
                    android:padding="@dimen/card_padding"
                    android:layout_marginEnd="3dp">

                    <TextView
                        android:id="@+id/tvBrainTotalTrades"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Trades"
                        android:textColor="#4B5563"
                        android:textSize="9sp"
                        android:fontFamily="monospace"/>

                </LinearLayout>

                <!-- Active Users -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/section_card_bg"
                    android:padding="@dimen/card_padding"
                    android:layout_marginStart="3dp"
                    android:layout_marginEnd="3dp">

                    <TextView
                        android:id="@+id/tvBrainActiveInstances"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#9945FF"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Users"
                        android:textColor="#4B5563"
                        android:textSize="9sp"
                        android:fontFamily="monospace"/>

                </LinearLayout>

                <!-- Patterns -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/section_card_bg"
                    android:padding="@dimen/card_padding"
                    android:layout_marginStart="3dp">

                    <TextView
                        android:id="@+id/tvBrainPatternsLearned"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#14F195"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Patterns"
                        android:textColor="#4B5563"
                        android:textSize="9sp"
                        android:fontFamily="monospace"/>

                </LinearLayout>

            </LinearLayout>

            <!-- ── P&L ROW ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/card_margin">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/section_card_bg"
                    android:padding="12dp"
                    android:layout_marginEnd="3dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="24h PROFIT"
                        android:textColor="#4B5563"
                        android:textSize="8sp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="3dp"/>

                    <TextView
                        android:id="@+id/tvBrainTotalProfit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#10B981"
                        android:textSize="@dimen/token_name_size"
                        android:textStyle="bold"
                        android:fontFamily="monospace"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/section_card_bg"
                    android:padding="12dp"
                    android:layout_marginStart="3dp"
                    android:layout_marginEnd="3dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="WIN RATE"
                        android:textColor="#4B5563"
                        android:textSize="8sp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="3dp"/>

                    <TextView
                        android:id="@+id/tvBrainWinRate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#9945FF"
                        android:textSize="@dimen/token_name_size"
                        android:textStyle="bold"
                        android:fontFamily="monospace"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/section_card_bg"
                    android:padding="12dp"
                    android:layout_marginStart="3dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AVG HOLD"
                        android:textColor="#4B5563"
                        android:textSize="8sp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="3dp"/>

                    <TextView
                        android:id="@+id/tvBrainAvgHold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#FFFFFF"
                        android:textSize="@dimen/token_name_size"
                        android:textStyle="bold"
                        android:fontFamily="monospace"/>

                </LinearLayout>

            </LinearLayout>

            <!-- ── SECTION: TOP PATTERNS ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/inner_gap">

                <View
                    android:layout_width="3dp"
                    android:layout_height="14dp"
                    android:background="#9945FF"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="TOP PATTERNS"
                    android:textColor="#9945FF"
                    android:textSize="@dimen/section_title_size"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.1"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/llBrainPatterns"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="@dimen/card_margin">

                <TextView
                    android:id="@+id/tvNoBrainData"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Learning from live trades…"
                    android:textColor="#4B5563"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:padding="20dp"/>

            </LinearLayout>

            <!-- ── SECTION: RECENT SIGNALS ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/inner_gap">

                <View
                    android:layout_width="3dp"
                    android:layout_height="14dp"
                    android:background="#14F195"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="RECENT SIGNALS"
                    android:textColor="#14F195"
                    android:textSize="@dimen/section_title_size"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.1"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/llBrainSignals"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No recent signals"
                    android:textColor="#4B5563"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:padding="20dp"/>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
