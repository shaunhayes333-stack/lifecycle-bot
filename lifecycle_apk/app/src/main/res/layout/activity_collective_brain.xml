<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A0F"
    android:fitsSystemWindows="true">

    <!-- ── TOP BAR ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/topbar_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/screen_padding"
        android:paddingEnd="@dimen/screen_padding"
        android:background="#0A0A0F">

        <TextView
            android:id="@+id/btnBrainBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:paddingEnd="12dp"
            android:clickable="true"
            android:focusable="true"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HIVE MIND"
                android:textColor="#9945FF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:letterSpacing="0.12"/>

            <TextView
                android:id="@+id/tvSyncStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Checking…"
                android:textColor="#4B5563"
                android:textSize="9sp"
                android:fontFamily="monospace"/>

        </LinearLayout>

        <!-- Data source badge -->
        <TextView
            android:id="@+id/tvBrainDataSource"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:gravity="center"
            android:text="LOCAL"
            android:textColor="#9945FF"
            android:textSize="9sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:background="@drawable/pill_bg"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:layout_marginEnd="6dp"/>

        <!-- Sync now -->
        <TextView
            android:id="@+id/btnForceSync"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:gravity="center"
            android:text="↻ Sync"
            android:textColor="#000000"
            android:textSize="10sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:background="@drawable/pill_bg_green"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

    <!-- Purple accent divider — this is the hive's pulse line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2D1B69"/>

    <!-- ── SCROLLABLE CONTENT ── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/screen_padding"
            android:paddingEnd="@dimen/screen_padding"
            android:paddingTop="@dimen/card_margin"
            android:paddingBottom="@dimen/content_bottom_padding">

            <!-- ── BRAIN ANIMATION ── -->
            <com.lifecyclebot.ui.AnimatedBrainView
                android:id="@+id/brainView"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_gravity="center"
                android:layout_marginBottom="@dimen/card_margin"/>

            <!-- ── BOOST BUTTON ── -->
            <TextView
                android:id="@+id/btnBoost"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:gravity="center"
                android:text="⚡ BOOST — Scan &amp; Backtest"
                android:textColor="#000000"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:letterSpacing="0.05"
                android:background="@drawable/pill_bg_yellow"
                android:layout_marginBottom="@dimen/card_margin"
                android:clickable="true"
                android:focusable="true"/>

            <!-- ── NODE STATS ROW — The network's heartbeat ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/inner_gap">

                <!-- Total Trades -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/section_card_bg"
                    android:padding="@dimen/card_padding"
                    android:layout_marginEnd="3dp">

                    <TextView
                        android:id="@+id/tvBrainTotalTrades"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TRADES"
                        android:textColor="#4B5563"
                        android:textSize="8sp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.10"/>

                </LinearLayout>

                <!-- Active Nodes -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/section_card_bg"
                    android:padding="@dimen/card_padding"
                    android:layout_marginStart="3dp"
                    android:layout_marginEnd="3dp">

                    <TextView
                        android:id="@+id/tvBrainActiveInstances"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#9945FF"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NODES"
                        android:textColor="#4B5563"
                        android:textSize="8sp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.10"/>

                </LinearLayout>

                <!-- Patterns Learned -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/section_card_bg"
                    android:padding="@dimen/card_padding"
                    android:layout_marginStart="3dp">

                    <TextView
                        android:id="@+id/tvBrainPatternsLearned"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#14F195"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PATTERNS"
                        android:textColor="#4B5563"
                        android:textSize="8sp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.10"/>

                </LinearLayout>

            </LinearLayout>

            <!-- ── COLLECTIVE PERFORMANCE ROW ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/card_margin">

                <!-- 24h Profit -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/section_card_bg"
                    android:padding="12dp"
                    android:layout_marginEnd="3dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="24h PROFIT"
                        android:textColor="#4B5563"
                        android:textSize="8sp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvBrainTotalProfit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#14F195"
                        android:textSize="@dimen/token_name_size"
                        android:textStyle="bold"
                        android:fontFamily="monospace"/>

                </LinearLayout>

                <!-- Win Rate -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/section_card_bg"
                    android:padding="12dp"
                    android:layout_marginStart="3dp"
                    android:layout_marginEnd="3dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="WIN RATE"
                        android:textColor="#4B5563"
                        android:textSize="8sp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvBrainWinRate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#9945FF"
                        android:textSize="@dimen/token_name_size"
                        android:textStyle="bold"
                        android:fontFamily="monospace"/>

                </LinearLayout>

                <!-- Avg Hold -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/section_card_bg"
                    android:padding="12dp"
                    android:layout_marginStart="3dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AVG HOLD"
                        android:textColor="#4B5563"
                        android:textSize="8sp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvBrainAvgHold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#FFFFFF"
                        android:textSize="@dimen/token_name_size"
                        android:textStyle="bold"
                        android:fontFamily="monospace"/>

                </LinearLayout>

            </LinearLayout>

            <!-- ── HIVE INTELLIGENCE ROW — blacklist + total loss ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/card_margin">

                <!-- Blacklisted tokens -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/section_card_bg"
                    android:padding="12dp"
                    android:layout_marginEnd="3dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BLACKLISTED"
                        android:textColor="#4B5563"
                        android:textSize="8sp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvBrainBlacklistedTokens"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#EF4444"
                        android:textSize="@dimen/token_name_size"
                        android:textStyle="bold"
                        android:fontFamily="monospace"/>

                </LinearLayout>

                <!-- Total network loss prevented -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/section_card_bg"
                    android:padding="12dp"
                    android:layout_marginStart="3dp"
                    android:layout_marginEnd="3dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NETWORK SOURCE"
                        android:textColor="#4B5563"
                        android:textSize="8sp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvBrainTotalLoss"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Local"
                        android:textColor="#6B7280"
                        android:textSize="@dimen/token_name_size"
                        android:textStyle="bold"
                        android:fontFamily="monospace"/>

                </LinearLayout>

                <!-- Top mode -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/section_card_bg"
                    android:padding="12dp"
                    android:layout_marginStart="3dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TOP MODE"
                        android:textColor="#4B5563"
                        android:textSize="8sp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvBrainTopMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#14F195"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"/>

                </LinearLayout>

            </LinearLayout>

            <!-- ── WORST MODE + SECTION HEADER ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/inner_gap">

                <View
                    android:layout_width="3dp"
                    android:layout_height="14dp"
                    android:background="#EF4444"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="AVOID"
                    android:textColor="#EF4444"
                    android:textSize="@dimen/section_title_size"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.12"/>

                <TextView
                    android:id="@+id/tvBrainWorstMode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#EF4444"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"/>

            </LinearLayout>

            <!-- ── MODE STATS CONTAINER (dynamic, filled by Kotlin) ── -->
            <LinearLayout
                android:id="@+id/llBrainModeStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/section_card_bg"
                android:padding="@dimen/card_padding"
                android:layout_marginBottom="@dimen/card_margin"/>

            <!-- ── TOP PATTERNS SECTION ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/inner_gap">

                <View
                    android:layout_width="3dp"
                    android:layout_height="14dp"
                    android:background="#9945FF"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="TOP PATTERNS"
                    android:textColor="#9945FF"
                    android:textSize="@dimen/section_title_size"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.12"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/llBrainPatterns"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="@dimen/card_margin">

                <TextView
                    android:id="@+id/tvNoBrainData"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Learning from live trades…"
                    android:textColor="#4B5563"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:padding="20dp"/>

            </LinearLayout>

            <!-- ── RECENT SIGNALS SECTION ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/inner_gap">

                <View
                    android:layout_width="3dp"
                    android:layout_height="14dp"
                    android:background="#14F195"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="NETWORK SIGNALS"
                    android:textColor="#14F195"
                    android:textSize="@dimen/section_title_size"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.12"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/llBrainSignals"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Awaiting signals from the hive…"
                    android:textColor="#4B5563"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:padding="20dp"/>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
