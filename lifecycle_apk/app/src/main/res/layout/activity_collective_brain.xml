<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A0F"
    android:fitsSystemWindows="true">

    <!-- ── TOP BAR ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="6dp"
        android:background="#0A0A0F">

        <TextView
            android:id="@+id/btnBrainBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:paddingEnd="12dp"
            android:clickable="true"
            android:focusable="true"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Collective Memory"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tvSyncStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Checking…"
                android:textColor="#6B7280"
                android:textSize="9sp"
                android:fontFamily="monospace"/>
        </LinearLayout>

        <!-- Data source badge -->
        <TextView
            android:id="@+id/tvBrainDataSource"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="LOCAL"
            android:textColor="#9945FF"
            android:textSize="9sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:background="@drawable/pill_bg"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:layout_marginEnd="8dp"/>

        <!-- Sync now -->
        <TextView
            android:id="@+id/btnForceSync"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="↻ Sync"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:background="@drawable/pill_bg_green"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#1F2937"/>

    <!-- ── SCROLLABLE CONTENT ── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="32dp">

            <!-- ── BRAIN ANIMATION ── -->
            <com.lifecyclebot.ui.AnimatedBrainView
                android:id="@+id/brainView"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:layout_gravity="center"
                android:layout_marginBottom="16dp"/>

            <!-- ── KEY STATS ROW ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <!-- Total Trades -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/section_card_bg"
                    android:padding="14dp"
                    android:layout_marginEnd="4dp">
                    <TextView
                        android:id="@+id/tvBrainTotalTrades"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Trades"
                        android:textColor="#6B7280"
                        android:textSize="9sp"/>
                </LinearLayout>

                <!-- Active Users -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/section_card_bg"
                    android:padding="14dp"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp">
                    <TextView
                        android:id="@+id/tvBrainActiveInstances"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#9945FF"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Users"
                        android:textColor="#6B7280"
                        android:textSize="9sp"/>
                </LinearLayout>

                <!-- Patterns -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/section_card_bg"
                    android:padding="14dp"
                    android:layout_marginStart="4dp">
                    <TextView
                        android:id="@+id/tvBrainPatternsLearned"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#14F195"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Patterns"
                        android:textColor="#6B7280"
                        android:textSize="9sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ── P&L ROW ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/section_card_bg"
                    android:padding="12dp"
                    android:layout_marginEnd="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="24h PROFIT"
                        android:textColor="#6B7280"
                        android:textSize="8sp"
                        android:fontFamily="monospace"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:id="@+id/tvBrainTotalProfit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#10B981"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/section_card_bg"
                    android:padding="12dp"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="24h LOSS"
                        android:textColor="#6B7280"
                        android:textSize="8sp"
                        android:fontFamily="monospace"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:id="@+id/tvBrainTotalLoss"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#EF4444"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/section_card_bg"
                    android:padding="12dp"
                    android:layout_marginStart="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BLACKLISTED"
                        android:textColor="#6B7280"
                        android:textSize="8sp"
                        android:fontFamily="monospace"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:id="@+id/tvBrainBlacklistedTokens"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#EF4444"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ── TOP PERFORMING PATTERNS ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="TOP PATTERNS"
                    android:textColor="#6B7280"
                    android:textSize="10sp"
                    android:letterSpacing="0.10"
                    android:fontFamily="monospace"/>
                <TextView
                    android:id="@+id/tvBrainTopMode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#10B981"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llBrainModeStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/section_card_bg"
                android:padding="14dp"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loading patterns…"
                    android:textColor="#6B7280"
                    android:textSize="12sp"/>
            </LinearLayout>

            <!-- ── WORST PATTERN ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/section_card_bg"
                android:padding="12dp"
                android:layout_marginBottom="20dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠ Worst: "
                    android:textColor="#6B7280"
                    android:textSize="11sp"/>
                <TextView
                    android:id="@+id/tvBrainWorstMode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#EF4444"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"/>
            </LinearLayout>

            <!-- ── FOOTER ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="The collective brain learns from all AATE instances. Patterns, modes, and token data are shared anonymously to improve trading decisions across the network."
                android:textColor="#374151"
                android:textSize="10sp"
                android:gravity="center"
                android:lineSpacingMultiplier="1.4"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
