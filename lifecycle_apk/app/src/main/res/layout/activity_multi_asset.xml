<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F"
    android:fitsSystemWindows="true">

    <!-- ═══════════════════════════════════════════════════════════════
         V5.7.6: MULTI-ASSET TRADING DASHBOARD
         Perps | Stocks | Commodities | Metals | Forex
         ═══════════════════════════════════════════════════════════════ -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ── TOP BAR ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/topbar_height"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/screen_padding"
            android:paddingEnd="@dimen/screen_padding"
            android:background="#0A0A0F">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="←"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:paddingEnd="12dp"
                android:clickable="true"
                android:focusable="true"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AATE Markets"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Perps · Stocks · Commodities · Metals · Forex"
                    android:textColor="#4B5563"
                    android:textSize="9sp"
                    android:fontFamily="monospace"/>

            </LinearLayout>

            <!-- Paper/Live mode toggle -->
            <Button
                android:id="@+id/btnModeToggle"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:text="PAPER"
                android:textColor="#000000"
                android:textSize="9sp"
                android:textStyle="bold"
                android:background="@drawable/pill_bg_yellow"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:layout_marginEnd="6dp"
                android:minWidth="50dp"/>

            <!-- Start/Stop -->
            <Button
                android:id="@+id/btnMarketsToggle"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:text="START"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@drawable/pill_bg_green"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:minWidth="70dp"/>

        </LinearLayout>

        <!-- ── HERO BALANCE ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/screen_padding"
            android:paddingEnd="@dimen/screen_padding"
            android:paddingBottom="@dimen/inner_gap">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BALANCE"
                android:textColor="#4B5563"
                android:textSize="9sp"
                android:letterSpacing="0.12"
                android:fontFamily="monospace"
                android:layout_marginBottom="2dp"/>

            <LinearLayout
                android:id="@+id/balanceContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tvTotalBalance"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="$0.00"
                    android:textColor="#00FF88"
                    android:textSize="@dimen/balance_text_size"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="14sp"
                    android:autoSizeMaxTextSize="34sp"
                    android:autoSizeStepGranularity="1sp"/>

                <TextView
                    android:id="@+id/tvBalanceSecondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#4B5563"
                    android:textSize="@dimen/balance_secondary_size"
                    android:layout_marginStart="8dp"
                    android:layout_marginBottom="4dp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- ── QUICK STATS BAR ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="@dimen/screen_padding"
            android:paddingEnd="@dimen/screen_padding"
            android:paddingTop="2dp"
            android:layout_marginBottom="@dimen/inner_gap">

            <!-- 24h Trades -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/section_card_bg"
                android:padding="5dp"
                android:layout_marginEnd="3dp">
                <TextView
                    android:id="@+id/tvStats24hTrades"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="24h"
                    android:textColor="#4B5563"
                    android:textSize="7sp"
                    android:fontFamily="monospace"/>
            </LinearLayout>

            <!-- Win Rate -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/section_card_bg"
                android:padding="5dp"
                android:layout_marginEnd="3dp">
                <TextView
                    android:id="@+id/tvStatsWinRate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—%"
                    android:textColor="#10B981"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WR"
                    android:textColor="#4B5563"
                    android:textSize="7sp"
                    android:fontFamily="monospace"/>
            </LinearLayout>

            <!-- Total P&L -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/section_card_bg"
                android:padding="5dp"
                android:layout_marginEnd="3dp">
                <TextView
                    android:id="@+id/tvStatsTotalPnl"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+0.00"
                    android:textColor="#00FF88"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="P&amp;L"
                    android:textColor="#4B5563"
                    android:textSize="7sp"
                    android:fontFamily="monospace"/>
            </LinearLayout>

            <!-- AI Score -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/section_card_bg"
                android:padding="5dp">
                <TextView
                    android:id="@+id/tvStatsAiScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#F59E0B"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI"
                    android:textColor="#4B5563"
                    android:textSize="7sp"
                    android:fontFamily="monospace"/>
            </LinearLayout>

        </LinearLayout>

        <!-- ── READINESS GAUGE (compact) ── -->
        <LinearLayout
            android:id="@+id/cardMarketsReadiness"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/section_card_bg"
            android:paddingStart="@dimen/screen_padding"
            android:paddingEnd="@dimen/screen_padding"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginStart="@dimen/screen_padding"
            android:layout_marginEnd="@dimen/screen_padding"
            android:layout_marginBottom="4dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚀"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/tvMarketsWinRate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#10B981"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginStart="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WR"
                android:textColor="#4B5563"
                android:textSize="8sp"
                android:fontFamily="monospace"
                android:layout_marginStart="2dp"/>

            <View
                android:layout_width="1dp"
                android:layout_height="14dp"
                android:background="#1F2937"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tvMarketsTrades"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0/5000"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:fontFamily="monospace"/>

            <View
                android:layout_width="1dp"
                android:layout_height="14dp"
                android:background="#1F2937"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tvMarketsPhase"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BOOT"
                android:textColor="#F59E0B"
                android:textSize="9sp"
                android:textStyle="bold"
                android:fontFamily="monospace"/>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <TextView
                android:id="@+id/tvMarketsProgressPct"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textColor="#FFD700"
                android:textSize="10sp"
                android:textStyle="bold"
                android:fontFamily="monospace"/>

            <TextView
                android:id="@+id/tvMarketsReadinessBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LEARN"
                android:textColor="#000000"
                android:textSize="8sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:background="@drawable/pill_bg_yellow"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:layout_marginStart="6dp"/>

        </LinearLayout>

        <!-- Progress bar -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_marginStart="@dimen/screen_padding"
            android:layout_marginEnd="@dimen/screen_padding"
            android:layout_marginBottom="4dp"
            android:background="@drawable/progress_bar_bg">

            <View
                android:id="@+id/viewMarketsProgressBar"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:background="@drawable/progress_bar_fill_gold"/>

        </FrameLayout>

        <TextView
            android:id="@+id/tvMarketsRecommendation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#4B5563"
            android:textSize="9sp"
            android:layout_marginStart="@dimen/screen_padding"
            android:layout_marginEnd="@dimen/screen_padding"
            android:layout_marginBottom="4dp"
            android:visibility="gone"/>

        <!-- ── AI LAYERS BAR (compact) ── -->
        <LinearLayout
            android:id="@+id/cardMarketsLayers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/section_card_bg"
            android:paddingStart="@dimen/screen_padding"
            android:paddingEnd="@dimen/screen_padding"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:layout_marginStart="@dimen/screen_padding"
            android:layout_marginEnd="@dimen/screen_padding"
            android:layout_marginBottom="4dp"
            android:gravity="center_vertical">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🧠" android:textSize="10sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="RSI" android:textColor="#4B5563" android:textSize="7sp" android:fontFamily="monospace" android:layout_marginStart="4dp"/>
            <TextView android:id="@+id/tvLayerRsi" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="--" android:textColor="#22C55E" android:textSize="9sp" android:textStyle="bold" android:layout_marginStart="2dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="MACD" android:textColor="#4B5563" android:textSize="7sp" android:fontFamily="monospace" android:layout_marginStart="6dp"/>
            <TextView android:id="@+id/tvLayerMacd" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="--" android:textColor="#22C55E" android:textSize="9sp" android:textStyle="bold" android:layout_marginStart="2dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="VOL" android:textColor="#4B5563" android:textSize="7sp" android:fontFamily="monospace" android:layout_marginStart="6dp"/>
            <TextView android:id="@+id/tvLayerVolume" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="--" android:textColor="#22C55E" android:textSize="9sp" android:textStyle="bold" android:layout_marginStart="2dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="S/R" android:textColor="#4B5563" android:textSize="7sp" android:fontFamily="monospace" android:layout_marginStart="6dp"/>
            <TextView android:id="@+id/tvLayerSR" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="--" android:textColor="#22C55E" android:textSize="9sp" android:textStyle="bold" android:layout_marginStart="2dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="MOM" android:textColor="#4B5563" android:textSize="7sp" android:fontFamily="monospace" android:layout_marginStart="6dp"/>
            <TextView android:id="@+id/tvLayerMomentum" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="--" android:textColor="#22C55E" android:textSize="9sp" android:textStyle="bold" android:layout_marginStart="2dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="SEC" android:textColor="#4B5563" android:textSize="7sp" android:fontFamily="monospace" android:layout_marginStart="6dp"/>
            <TextView android:id="@+id/tvLayerSector" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="--" android:textColor="#22C55E" android:textSize="9sp" android:textStyle="bold" android:layout_marginStart="2dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="COR" android:textColor="#4B5563" android:textSize="7sp" android:fontFamily="monospace" android:layout_marginStart="6dp"/>
            <TextView android:id="@+id/tvLayerCorrel" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="--" android:textColor="#22C55E" android:textSize="9sp" android:textStyle="bold" android:layout_marginStart="2dp"/>

            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

            <TextView android:id="@+id/tvMarketsLearningEvents" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0" android:textColor="#00FF88" android:textSize="9sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📚" android:textSize="8sp" android:layout_marginStart="2dp"/>
            <TextView android:id="@+id/tvMarketsCrossSync" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="OK" android:textColor="#00FF88" android:textSize="8sp" android:textStyle="bold" android:layout_marginStart="6dp"/>

            <!-- hidden compat field -->
            <TextView android:id="@+id/tvMarketsLayerCount" android:layout_width="0dp" android:layout_height="0dp"
                android:text="7" android:visibility="gone"/>

        </LinearLayout>

        <!-- ── QUICK ACTIONS BAR ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="@dimen/screen_padding"
            android:paddingEnd="@dimen/screen_padding"
            android:layout_marginBottom="4dp">

            <LinearLayout
                android:id="@+id/btnJournal"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/section_card_bg"
                android:layout_marginEnd="3dp"
                android:clickable="true"
                android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📒" android:textSize="11sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Log" android:textColor="#6B7280" android:textSize="8sp"
                    android:fontFamily="monospace" android:layout_marginStart="3dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnTaxReport"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/section_card_bg"
                android:layout_marginEnd="3dp"
                android:clickable="true"
                android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📋" android:textSize="11sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Tax" android:textColor="#6B7280" android:textSize="8sp"
                    android:fontFamily="monospace" android:layout_marginStart="3dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnPerformance"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/section_card_bg"
                android:layout_marginEnd="3dp"
                android:clickable="true"
                android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📊" android:textSize="11sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Stats" android:textColor="#6B7280" android:textSize="8sp"
                    android:fontFamily="monospace" android:layout_marginStart="3dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnExport"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/section_card_bg"
                android:clickable="true"
                android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📤" android:textSize="11sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Export" android:textColor="#6B7280" android:textSize="8sp"
                    android:fontFamily="monospace" android:layout_marginStart="3dp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- ── TABS ── -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayout"
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:background="#0A0A0F"
            app:tabMode="scrollable"
            app:tabGravity="start"
            app:tabTextColor="#4B5563"
            app:tabSelectedTextColor="#00FF88"
            app:tabIndicatorColor="#00FF88"
            app:tabIndicatorHeight="2dp"
            app:tabPaddingStart="@dimen/screen_padding"
            app:tabPaddingEnd="@dimen/screen_padding"
            app:tabMinWidth="80dp"/>

        <!-- Accent line under tabs -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#111827"/>

        <!-- ── MAIN CONTENT AREA ── -->
        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipeRefresh"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="@dimen/screen_padding"
                    android:paddingEnd="@dimen/screen_padding"
                    android:paddingTop="@dimen/inner_gap"
                    android:paddingBottom="120dp">

                    <!-- ═══════════════════════════════════════════════════
                         ACTIVE POSITIONS
                         ═══════════════════════════════════════════════════ -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/section_card_bg"
                        android:padding="@dimen/card_padding"
                        android:layout_marginBottom="@dimen/card_margin_bottom">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="@dimen/inner_gap">

                            <View
                                android:layout_width="3dp"
                                android:layout_height="14dp"
                                android:background="#9945FF"
                                android:layout_marginEnd="8dp"/>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="ACTIVE POSITIONS"
                                android:textColor="#9945FF"
                                android:textSize="@dimen/section_title_size"
                                android:textStyle="bold"
                                android:fontFamily="monospace"
                                android:letterSpacing="0.1"/>

                            <TextView
                                android:id="@+id/tvActivePositionsCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#4B5563"
                                android:textSize="10sp"
                                android:fontFamily="monospace"/>

                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/positionsContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvNoPositions"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="No active positions\nWaiting for signals..."
                                android:textColor="#4B5563"
                                android:textSize="11sp"
                                android:fontFamily="monospace"
                                android:gravity="center"
                                android:padding="20dp"/>

                        </LinearLayout>

                    </LinearLayout>

                    <!-- ═══════════════════════════════════════════════════
                         TOP MOVERS
                         ═══════════════════════════════════════════════════ -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/section_card_bg"
                        android:padding="@dimen/card_padding"
                        android:layout_marginBottom="@dimen/card_margin_bottom">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="@dimen/inner_gap">

                            <View
                                android:layout_width="3dp"
                                android:layout_height="14dp"
                                android:background="#F59E0B"
                                android:layout_marginEnd="8dp"/>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="🔥 TOP MOVERS"
                                android:textColor="#F59E0B"
                                android:textSize="@dimen/section_title_size"
                                android:textStyle="bold"
                                android:fontFamily="monospace"
                                android:letterSpacing="0.1"/>

                            <TextView
                                android:id="@+id/tvTopMoversTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="24h"
                                android:textColor="#4B5563"
                                android:textSize="9sp"
                                android:fontFamily="monospace"/>

                        </LinearLayout>

                        <HorizontalScrollView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:scrollbars="none">
                            <LinearLayout
                                android:id="@+id/topMoversContainer"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"/>
                        </HorizontalScrollView>

                    </LinearLayout>

                    <!-- ═══════════════════════════════════════════════════
                         AI SIGNALS PANEL
                         ═══════════════════════════════════════════════════ -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/section_card_bg"
                        android:padding="@dimen/card_padding"
                        android:layout_marginBottom="@dimen/card_margin_bottom">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="@dimen/inner_gap">

                            <View
                                android:layout_width="3dp"
                                android:layout_height="14dp"
                                android:background="#00FF88"
                                android:layout_marginEnd="8dp"/>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="🤖 AI SIGNALS"
                                android:textColor="#00FF88"
                                android:textSize="@dimen/section_title_size"
                                android:textStyle="bold"
                                android:fontFamily="monospace"
                                android:letterSpacing="0.1"/>

                            <View
                                android:id="@+id/aiSignalDot"
                                android:layout_width="6dp"
                                android:layout_height="6dp"
                                android:background="@drawable/dot_green"
                                android:layout_marginEnd="4dp"/>

                            <TextView
                                android:id="@+id/tvAiSignalStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Scanning..."
                                android:textColor="#00FF88"
                                android:textSize="9sp"
                                android:fontFamily="monospace"/>

                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/aiSignalsContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvNoAiSignals"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="AI analyzing markets..."
                                android:textColor="#4B5563"
                                android:textSize="11sp"
                                android:fontFamily="monospace"
                                android:gravity="center"
                                android:padding="12dp"/>

                        </LinearLayout>

                    </LinearLayout>

                    <!-- ═══════════════════════════════════════════════════
                         SECTOR HEATMAP
                         ═══════════════════════════════════════════════════ -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/section_card_bg"
                        android:padding="@dimen/card_padding"
                        android:layout_marginBottom="@dimen/card_margin_bottom">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="@dimen/inner_gap">

                            <View
                                android:layout_width="3dp"
                                android:layout_height="14dp"
                                android:background="#3B82F6"
                                android:layout_marginEnd="8dp"/>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="🗺️ SECTOR HEATMAP"
                                android:textColor="#3B82F6"
                                android:textSize="@dimen/section_title_size"
                                android:textStyle="bold"
                                android:fontFamily="monospace"
                                android:letterSpacing="0.1"/>

                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/heatmapContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginBottom="4dp">

                                <TextView android:id="@+id/heatTech"
                                    android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                                    android:text="TECH\n+2.1%" android:textColor="#FFFFFF" android:textSize="9sp"
                                    android:gravity="center" android:background="#1A10B981"
                                    android:fontFamily="monospace" android:layout_marginEnd="3dp"/>

                                <TextView android:id="@+id/heatFinance"
                                    android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                                    android:text="FINANCE\n-0.8%" android:textColor="#FFFFFF" android:textSize="9sp"
                                    android:gravity="center" android:background="#1AEF4444"
                                    android:fontFamily="monospace" android:layout_marginEnd="3dp"/>

                                <TextView android:id="@+id/heatEnergy"
                                    android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                                    android:text="ENERGY\n+1.2%" android:textColor="#FFFFFF" android:textSize="9sp"
                                    android:gravity="center" android:background="#1A10B981"
                                    android:fontFamily="monospace"/>

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <TextView android:id="@+id/heatMetals"
                                    android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                                    android:text="METALS\n+0.3%" android:textColor="#FFFFFF" android:textSize="9sp"
                                    android:gravity="center" android:background="#1A10B981"
                                    android:fontFamily="monospace" android:layout_marginEnd="3dp"/>

                                <TextView android:id="@+id/heatForex"
                                    android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                                    android:text="FOREX\n-0.1%" android:textColor="#FFFFFF" android:textSize="9sp"
                                    android:gravity="center" android:background="#1AEF4444"
                                    android:fontFamily="monospace" android:layout_marginEnd="3dp"/>

                                <TextView android:id="@+id/heatCrypto"
                                    android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                                    android:text="CRYPTO\n+4.7%" android:textColor="#FFFFFF" android:textSize="9sp"
                                    android:gravity="center" android:background="#2210B981"
                                    android:fontFamily="monospace"/>

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </androidx.core.widget.NestedScrollView>

        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
