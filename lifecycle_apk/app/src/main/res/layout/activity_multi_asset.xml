<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F">

    <!-- ═══════════════════════════════════════════════════════════════
         V5.7.6: MULTI-ASSET TRADING DASHBOARD
         Perps | Stocks | Commodities | Metals | Forex
         ═══════════════════════════════════════════════════════════════ -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ── TOP BAR ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="8dp"
            android:background="#0A0A0F">

            <!-- Back button -->
            <TextView
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="←"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:paddingEnd="12dp"
                android:clickable="true"
                android:focusable="true"/>

            <!-- Title -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Multi-Asset Trading"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tvSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Perps • Stocks • Commodities • Metals • Forex"
                    android:textColor="#6B7280"
                    android:textSize="10sp"/>
            </LinearLayout>

            <!-- Combined Balance -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end"
                android:background="@drawable/pill_bg"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PAPER BAL"
                    android:textColor="#6B7280"
                    android:textSize="8sp"/>
                <TextView
                    android:id="@+id/tvTotalBalance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="250.00 ◎"
                    android:textColor="#00FF88"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ── TAB LAYOUT ── -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#111118"
            app:tabMode="scrollable"
            app:tabGravity="start"
            app:tabTextColor="#6B7280"
            app:tabSelectedTextColor="#00FF88"
            app:tabIndicatorColor="#00FF88"
            app:tabIndicatorHeight="2dp"
            app:tabPaddingStart="12dp"
            app:tabPaddingEnd="12dp"
            app:tabMinWidth="80dp"/>

        <!-- ── MAIN CONTENT AREA ── -->
        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipeRefresh"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <!-- ═══════════════════════════════════════════════════
                         SUMMARY CARDS ROW
                         ═══════════════════════════════════════════════════ -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <!-- Active Positions -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@drawable/section_card_bg"
                            android:padding="10dp"
                            android:layout_marginEnd="6dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="POSITIONS"
                                android:textColor="#6B7280"
                                android:textSize="9sp"/>
                            <TextView
                                android:id="@+id/tvActivePositions"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#FFFFFF"
                                android:textSize="20sp"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <!-- Today's P&L -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@drawable/section_card_bg"
                            android:padding="10dp"
                            android:layout_marginEnd="6dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="TODAY P&amp;L"
                                android:textColor="#6B7280"
                                android:textSize="9sp"/>
                            <TextView
                                android:id="@+id/tvTodayPnl"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="+0.00 ◎"
                                android:textColor="#00FF88"
                                android:textSize="16sp"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <!-- Win Rate -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@drawable/section_card_bg"
                            android:padding="10dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="WIN RATE"
                                android:textColor="#6B7280"
                                android:textSize="9sp"/>
                            <TextView
                                android:id="@+id/tvWinRate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="#FFD700"
                                android:textSize="16sp"
                                android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- ═══════════════════════════════════════════════════
                         CATEGORY HEADER (changes with tab)
                         ═══════════════════════════════════════════════════ -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:id="@+id/tvCategoryIcon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📈"
                            android:textSize="18sp"
                            android:layout_marginEnd="8dp"/>
                        <TextView
                            android:id="@+id/tvCategoryTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="TOKENIZED STOCKS"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/tvCategoryCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="47 assets"
                            android:textColor="#6B7280"
                            android:textSize="11sp"/>
                    </LinearLayout>

                    <!-- ═══════════════════════════════════════════════════
                         SPOT vs LEVERAGE TOGGLE
                         ═══════════════════════════════════════════════════ -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:id="@+id/btnSpotMode"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="💰 SPOT (1x)"
                            android:textColor="#00FF88"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:padding="10dp"
                            android:background="@drawable/tab_selected_bg"
                            android:layout_marginEnd="4dp"
                            android:clickable="true"
                            android:focusable="true"/>

                        <TextView
                            android:id="@+id/btnLeverageMode"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="⚡ LEVERAGE"
                            android:textColor="#6B7280"
                            android:textSize="12sp"
                            android:gravity="center"
                            android:padding="10dp"
                            android:background="@drawable/section_card_bg"
                            android:layout_marginStart="4dp"
                            android:clickable="true"
                            android:focusable="true"/>
                    </LinearLayout>

                    <!-- ═══════════════════════════════════════════════════
                         ACTIVE POSITIONS LIST
                         ═══════════════════════════════════════════════════ -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/section_card_bg"
                        android:padding="12dp"
                        android:layout_marginBottom="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Active Positions"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:id="@+id/tvPositionCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 open"
                                android:textColor="#6B7280"
                                android:textSize="11sp"/>
                        </LinearLayout>

                        <!-- Positions will be added here dynamically -->
                        <LinearLayout
                            android:id="@+id/positionsContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <!-- Empty state -->
                            <TextView
                                android:id="@+id/tvNoPositions"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="No active positions\nWaiting for signals..."
                                android:textColor="#6B7280"
                                android:textSize="12sp"
                                android:gravity="center"
                                android:padding="20dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- ═══════════════════════════════════════════════════
                         RECENT SIGNALS / ACTIVITY
                         ═══════════════════════════════════════════════════ -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/section_card_bg"
                        android:padding="12dp"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Recent Signals"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp"/>

                        <LinearLayout
                            android:id="@+id/signalsContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvNoSignals"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Scanning markets..."
                                android:textColor="#6B7280"
                                android:textSize="12sp"
                                android:gravity="center"
                                android:padding="16dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- ═══════════════════════════════════════════════════
                         ASSET CATEGORIES GRID (for current tab)
                         ═══════════════════════════════════════════════════ -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/section_card_bg"
                        android:padding="12dp"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Available Assets"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp"/>

                        <!-- Asset grid will be populated dynamically -->
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvAssets"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"/>
                    </LinearLayout>

                    <!-- ═══════════════════════════════════════════════════
                         ENGINE STATUS
                         ═══════════════════════════════════════════════════ -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/section_card_bg"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Engine Status"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <!-- Stock Trader -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="8dp">
                                <View
                                    android:id="@+id/dotStocks"
                                    android:layout_width="8dp"
                                    android:layout_height="8dp"
                                    android:background="@drawable/dot_green"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Stocks"
                                    android:textColor="#6B7280"
                                    android:textSize="9sp"
                                    android:layout_marginTop="4dp"/>
                            </LinearLayout>

                            <!-- Commodities Trader -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="8dp">
                                <View
                                    android:id="@+id/dotCommodities"
                                    android:layout_width="8dp"
                                    android:layout_height="8dp"
                                    android:background="@drawable/dot_green"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Commodities"
                                    android:textColor="#6B7280"
                                    android:textSize="9sp"
                                    android:layout_marginTop="4dp"/>
                            </LinearLayout>

                            <!-- Metals Trader -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="8dp">
                                <View
                                    android:id="@+id/dotMetals"
                                    android:layout_width="8dp"
                                    android:layout_height="8dp"
                                    android:background="@drawable/dot_green"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Metals"
                                    android:textColor="#6B7280"
                                    android:textSize="9sp"
                                    android:layout_marginTop="4dp"/>
                            </LinearLayout>

                            <!-- Forex Trader -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="8dp">
                                <View
                                    android:id="@+id/dotForex"
                                    android:layout_width="8dp"
                                    android:layout_height="8dp"
                                    android:background="@drawable/dot_green"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Forex"
                                    android:textColor="#6B7280"
                                    android:textSize="9sp"
                                    android:layout_marginTop="4dp"/>
                            </LinearLayout>

                            <!-- Perps Engine -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="8dp">
                                <View
                                    android:id="@+id/dotPerps"
                                    android:layout_width="8dp"
                                    android:layout_height="8dp"
                                    android:background="@drawable/dot_green"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Perps"
                                    android:textColor="#6B7280"
                                    android:textSize="9sp"
                                    android:layout_marginTop="4dp"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
