<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- ── TOP BAR ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/screen_padding"
        android:paddingEnd="@dimen/screen_padding"
        android:paddingTop="10dp"
        android:paddingBottom="8dp"
        android:background="#0A0A0F">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:background="@android:color/transparent"
            android:padding="8dp"
            android:contentDescription="Back"
            android:clickable="true"
            android:focusable="true"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NEURAL PERSONALITY"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:letterSpacing="0.06"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Instinct  ·  Plasticity  ·  Layer Health"
                android:textColor="#6B7280"
                android:textSize="9sp"
                android:fontFamily="monospace"/>
        </LinearLayout>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#111827"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/screen_padding"
            android:paddingEnd="@dimen/screen_padding"
            android:paddingTop="12dp"
            android:paddingBottom="32dp">

            <!-- ══ AGGRESSION DIAL ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/section_card_bg"
                android:padding="@dimen/card_padding"
                android:layout_marginBottom="@dimen/card_margin_bottom">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="INSTINCT DIAL"
                    android:textColor="#F59E0B"
                    android:textSize="10sp"
                    android:letterSpacing="0.12"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:layout_marginBottom="16dp"/>

                <!-- LED Strip - use layout_weight so they scale with screen width -->
                <LinearLayout
                    android:id="@+id/ledStrip"
                    android:layout_width="match_parent"
                    android:layout_height="22dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="12dp">
                    <View android:id="@+id/led0" android:layout_width="0dp" android:layout_height="16dp" android:layout_weight="1" android:layout_marginStart="2dp" android:layout_marginEnd="2dp" android:background="@drawable/led_off"/>
                    <View android:id="@+id/led1" android:layout_width="0dp" android:layout_height="16dp" android:layout_weight="1" android:layout_marginStart="2dp" android:layout_marginEnd="2dp" android:background="@drawable/led_off"/>
                    <View android:id="@+id/led2" android:layout_width="0dp" android:layout_height="16dp" android:layout_weight="1" android:layout_marginStart="2dp" android:layout_marginEnd="2dp" android:background="@drawable/led_off"/>
                    <View android:id="@+id/led3" android:layout_width="0dp" android:layout_height="16dp" android:layout_weight="1" android:layout_marginStart="2dp" android:layout_marginEnd="2dp" android:background="@drawable/led_off"/>
                    <View android:id="@+id/led4" android:layout_width="0dp" android:layout_height="16dp" android:layout_weight="1" android:layout_marginStart="2dp" android:layout_marginEnd="2dp" android:background="@drawable/led_off"/>
                    <View android:id="@+id/led5" android:layout_width="0dp" android:layout_height="16dp" android:layout_weight="1" android:layout_marginStart="2dp" android:layout_marginEnd="2dp" android:background="@drawable/led_off"/>
                    <View android:id="@+id/led6" android:layout_width="0dp" android:layout_height="16dp" android:layout_weight="1" android:layout_marginStart="2dp" android:layout_marginEnd="2dp" android:background="@drawable/led_off"/>
                    <View android:id="@+id/led7" android:layout_width="0dp" android:layout_height="16dp" android:layout_weight="1" android:layout_marginStart="2dp" android:layout_marginEnd="2dp" android:background="@drawable/led_off"/>
                    <View android:id="@+id/led8" android:layout_width="0dp" android:layout_height="16dp" android:layout_weight="1" android:layout_marginStart="2dp" android:layout_marginEnd="2dp" android:background="@drawable/led_off"/>
                    <View android:id="@+id/led9" android:layout_width="0dp" android:layout_height="16dp" android:layout_weight="1" android:layout_marginStart="2dp" android:layout_marginEnd="2dp" android:background="@drawable/led_off"/>
                    <View android:id="@+id/led10" android:layout_width="0dp" android:layout_height="16dp" android:layout_weight="1" android:layout_marginStart="2dp" android:layout_marginEnd="2dp" android:background="@drawable/led_off"/>
                    <View android:id="@+id/led11" android:layout_width="0dp" android:layout_height="16dp" android:layout_weight="1" android:layout_marginStart="2dp" android:layout_marginEnd="2dp" android:background="@drawable/led_off"/>
                </LinearLayout>

                <!-- Scale labels -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="DEFENSIVE" android:textColor="#4488FF" android:textSize="9sp"
                        android:fontFamily="monospace" android:gravity="start"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="NORMAL" android:textColor="#10B981" android:textSize="9sp"
                        android:fontFamily="monospace" android:gravity="center"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="AGGRESSIVE" android:textColor="#EF4444" android:textSize="9sp"
                        android:fontFamily="monospace" android:gravity="end"/>
                </LinearLayout>

                <SeekBar
                    android:id="@+id/knobSeekBar"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:max="11"
                    android:progress="5"
                    android:progressTint="#14F195"
                    android:thumbTint="#14F195"
                    android:progressBackgroundTint="#1F2937"/>

                <TextView
                    android:id="@+id/tvCurrentMode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="NORMAL"
                    android:textColor="#14F195"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:layout_marginTop="12dp"/>

                <TextView
                    android:id="@+id/tvModeDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Balanced buying and selling behavior"
                    android:textColor="#6B7280"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>

            <!-- ══ FLUID LEARNING IMPACT ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/section_card_bg"
                android:padding="@dimen/card_padding"
                android:layout_marginBottom="@dimen/card_margin_bottom">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FLUID LEARNING IMPACT"
                    android:textColor="#6B7280"
                    android:textSize="10sp"
                    android:letterSpacing="0.10"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:id="@+id/tvFluidAdjustment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0.00"
                    android:textColor="#14F195"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:gravity="center"/>

                <TextView
                    android:id="@+id/tvFluidDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Neutral — thresholds unchanged"
                    android:textColor="#6B7280"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- ══ BEHAVIOR METRICS ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/section_card_bg"
                android:padding="@dimen/card_padding"
                android:layout_marginBottom="@dimen/card_margin_bottom">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BEHAVIOR METRICS"
                    android:textColor="#6B7280"
                    android:textSize="10sp"
                    android:letterSpacing="0.10"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="14dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="12dp">
                    <!-- Streak -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="STREAK" android:textColor="#6B7280" android:textSize="9sp" android:fontFamily="monospace"/>
                        <TextView android:id="@+id/tvStreak" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textColor="#FFFFFF" android:textSize="@dimen/kpi_value_size"
                            android:textStyle="bold" android:fontFamily="monospace"/>
                    </LinearLayout>
                    <!-- Discipline -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="DISCIPLINE" android:textColor="#6B7280" android:textSize="9sp" android:fontFamily="monospace"/>
                        <TextView android:id="@+id/tvDiscipline" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="50%" android:textColor="#9945FF" android:textSize="@dimen/kpi_value_size"
                            android:textStyle="bold" android:fontFamily="monospace"/>
                    </LinearLayout>
                    <!-- Tilt -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="TILT" android:textColor="#6B7280" android:textSize="9sp" android:fontFamily="monospace"/>
                        <TextView android:id="@+id/tvTilt" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0%" android:textColor="#EF4444" android:textSize="@dimen/kpi_value_size"
                            android:textStyle="bold" android:fontFamily="monospace"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <!-- Sentiment -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="SENTIMENT" android:textColor="#6B7280" android:textSize="9sp" android:fontFamily="monospace"/>
                        <TextView android:id="@+id/tvSentiment" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="NEUTRAL" android:textColor="#FFFFFF" android:textSize="@dimen/kpi_value_size"
                            android:textStyle="bold" android:fontFamily="monospace"/>
                    </LinearLayout>
                    <!-- 10X -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="10X RUNS" android:textColor="#6B7280" android:textSize="9sp" android:fontFamily="monospace"/>
                        <TextView android:id="@+id/tvTenX" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textColor="#FFD700" android:textSize="@dimen/kpi_value_size"
                            android:textStyle="bold" android:fontFamily="monospace"/>
                    </LinearLayout>
                    <!-- 100X -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="100X RUNS" android:textColor="#6B7280" android:textSize="9sp" android:fontFamily="monospace"/>
                        <TextView android:id="@+id/tvHundredX" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textColor="#FF00FF" android:textSize="@dimen/kpi_value_size"
                            android:textStyle="bold" android:fontFamily="monospace"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ══ SESSION STATS ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/section_card_bg"
                android:padding="@dimen/card_padding"
                android:layout_marginBottom="@dimen/card_margin_bottom">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SESSION STATS"
                    android:textColor="#6B7280"
                    android:textSize="10sp"
                    android:letterSpacing="0.10"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="14dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tvSessionTrades"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textColor="#FFFFFF" android:textSize="24sp"
                            android:textStyle="bold" android:fontFamily="monospace"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="TRADES" android:textColor="#6B7280" android:textSize="9sp"
                            android:fontFamily="monospace" android:letterSpacing="0.08"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tvSessionWins"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textColor="#10B981" android:textSize="24sp"
                            android:textStyle="bold" android:fontFamily="monospace"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="WINS" android:textColor="#6B7280" android:textSize="9sp"
                            android:fontFamily="monospace" android:letterSpacing="0.08"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tvSessionLosses"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textColor="#EF4444" android:textSize="24sp"
                            android:textStyle="bold" android:fontFamily="monospace"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="LOSSES" android:textColor="#6B7280" android:textSize="9sp"
                            android:fontFamily="monospace" android:letterSpacing="0.08"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tvSessionBigWins"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textColor="#FFD700" android:textSize="24sp"
                            android:textStyle="bold" android:fontFamily="monospace"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="BIG WINS" android:textColor="#6B7280" android:textSize="9sp"
                            android:fontFamily="monospace" android:letterSpacing="0.08"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ══ NEURAL NETWORK STATUS ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/section_card_bg"
                android:padding="@dimen/card_padding"
                android:layout_marginBottom="@dimen/card_margin_bottom">

                <!-- Neural header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="NEURAL NETWORK"
                        android:textColor="#14F195"
                        android:textSize="10sp"
                        android:letterSpacing="0.10"
                        android:fontFamily="monospace"/>
                    <TextView
                        android:id="@+id/tvCurriculumLevel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FRESHMAN"
                        android:textColor="#FFD700"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:background="@drawable/chip_warn_bg"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"/>
                </LinearLayout>

                <!-- Brain network visualization -->
                <com.lifecyclebot.ui.BrainNetworkView
                    android:id="@+id/brainNetworkView"
                    android:layout_width="match_parent"
                    android:layout_height="240dp"
                    android:layout_marginBottom="14dp"/>

                <!-- Maturity bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MATURITY"
                        android:textColor="#6B7280"
                        android:textSize="9sp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.10"/>
                    <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>
                    <TextView
                        android:id="@+id/tvMaturityPct"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textColor="#14F195"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"/>
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressMaturity"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:layout_marginBottom="16dp"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:progressDrawable="@drawable/progress_brain_maturity"
                    android:max="100"
                    android:progress="0"/>

                <!-- Layer status grid -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/stat_card_bg"
                        android:padding="12dp"
                        android:layout_marginEnd="6dp">
                        <TextView android:id="@+id/tvActiveLayers"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textColor="#14F195" android:textSize="24sp"
                            android:textStyle="bold" android:fontFamily="monospace"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="ACTIVE" android:textColor="#14F195" android:textSize="9sp"
                            android:letterSpacing="0.08" android:fontFamily="monospace"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/stat_card_bg"
                        android:padding="12dp"
                        android:layout_marginStart="6dp"
                        android:layout_marginEnd="6dp">
                        <TextView android:id="@+id/tvDormantLayers"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textColor="#FF8800" android:textSize="24sp"
                            android:textStyle="bold" android:fontFamily="monospace"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="DORMANT" android:textColor="#FF8800" android:textSize="9sp"
                            android:letterSpacing="0.08" android:fontFamily="monospace"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/stat_card_bg"
                        android:padding="12dp"
                        android:layout_marginStart="6dp">
                        <TextView android:id="@+id/tvAvgAccuracy"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="50%" android:textColor="#FFFFFF" android:textSize="24sp"
                            android:textStyle="bold" android:fontFamily="monospace"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="ACCURACY" android:textColor="#6B7280" android:textSize="9sp"
                            android:letterSpacing="0.08" android:fontFamily="monospace"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Top performing layers -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/stat_card_bg"
                    android:padding="12dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="TOP PERFORMING LAYERS"
                        android:textColor="#14F195"
                        android:textSize="9sp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.10"
                        android:layout_marginBottom="6dp"/>
                    <TextView
                        android:id="@+id/tvTopLayers"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Awaiting data…"
                        android:textColor="#14F195"
                        android:textSize="10sp"
                        android:fontFamily="monospace"
                        android:lineSpacingExtra="3dp"/>
                    <TextView
                        android:id="@+id/tvDormantWarning"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#FF8800"
                        android:textSize="9sp"
                        android:fontFamily="monospace"
                        android:layout_marginTop="8dp"
                        android:visibility="gone"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ══ V5.9.10: SENTIENT MIND — SYMBOLIC REASONING DIALOGUE ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#0A0A14"
                android:padding="12dp"
                android:layout_marginTop="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🧠 SENTIENT MIND"
                        android:textColor="#9945FF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"/>
                    <TextView
                        android:id="@+id/tvSentientMood"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🧠"
                        android:textSize="18sp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvSentientDiagnostics"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SymCtx: initializing…"
                    android:textColor="#666"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="4dp"/>

                <ScrollView
                    android:id="@+id/scrollSentientChat"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_marginTop="8dp"
                    android:background="#05050A"
                    android:padding="10dp"
                    android:fillViewport="true">
                    <TextView
                        android:id="@+id/tvSentientChat"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Systems online. Awaiting first thought…"
                        android:textColor="#BBBBBB"
                        android:textSize="10sp"
                        android:fontFamily="monospace"
                        android:lineSpacingExtra="4dp"/>
                </ScrollView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">
                    <Button
                        android:id="@+id/btnSentientReflect"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="REFLECT"
                        android:textColor="#9945FF"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:backgroundTint="#14001A"
                        android:layout_marginEnd="6dp"/>
                    <Button
                        android:id="@+id/btnSentientClear"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="CLEAR"
                        android:textColor="#666"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:backgroundTint="#0A0A14"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ══ RESET BUTTONS ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <Button
                    android:id="@+id/btnResetLearning"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/bottom_bar_button_height"
                    android:layout_weight="1"
                    android:text="RESET LEARNING"
                    android:textColor="#FF8800"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:backgroundTint="#1A1000"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btnResetBehavior"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/bottom_bar_button_height"
                    android:layout_weight="1"
                    android:text="RESET STATE"
                    android:textColor="#EF4444"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:backgroundTint="#1A0808"
                    android:layout_marginStart="0dp"/>
            </LinearLayout>

            <!-- V5.9.18: Paper wallet recovery — resets paper cash only, preserves learning -->
            <Button
                android:id="@+id/btnResetPaperWallet"
                android:layout_width="match_parent"
                android:layout_height="@dimen/bottom_bar_button_height"
                android:text="RESET PAPER WALLET ($1000)"
                android:textColor="#14F195"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:backgroundTint="#00140A"
                android:layout_marginTop="8dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
