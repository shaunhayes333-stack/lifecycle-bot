<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_revert"
                android:contentDescription="Back"
                app:tint="#00FF88" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="BEHAVIOR TUNING"
                android:textColor="#00FF88"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:gravity="center"
                android:letterSpacing="0.15" />

            <View
                android:layout_width="40dp"
                android:layout_height="40dp" />
        </LinearLayout>

        <!-- Stereo Tuning Knob Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#1A1A1A"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Knob Title -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="AGGRESSION DIAL"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:letterSpacing="0.2"
                    android:gravity="center"
                    android:layout_marginBottom="8dp" />

                <!-- LED Indicator Strip -->
                <LinearLayout
                    android:id="@+id/ledStrip"
                    android:layout_width="match_parent"
                    android:layout_height="24dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="12dp">

                    <!-- 12 LED indicators (0-11) -->
                    <View android:id="@+id/led0" android:layout_width="18dp" android:layout_height="18dp" android:layout_margin="2dp" android:background="@drawable/led_off" />
                    <View android:id="@+id/led1" android:layout_width="18dp" android:layout_height="18dp" android:layout_margin="2dp" android:background="@drawable/led_off" />
                    <View android:id="@+id/led2" android:layout_width="18dp" android:layout_height="18dp" android:layout_margin="2dp" android:background="@drawable/led_off" />
                    <View android:id="@+id/led3" android:layout_width="18dp" android:layout_height="18dp" android:layout_margin="2dp" android:background="@drawable/led_off" />
                    <View android:id="@+id/led4" android:layout_width="18dp" android:layout_height="18dp" android:layout_margin="2dp" android:background="@drawable/led_off" />
                    <View android:id="@+id/led5" android:layout_width="18dp" android:layout_height="18dp" android:layout_margin="2dp" android:background="@drawable/led_off" />
                    <View android:id="@+id/led6" android:layout_width="18dp" android:layout_height="18dp" android:layout_margin="2dp" android:background="@drawable/led_off" />
                    <View android:id="@+id/led7" android:layout_width="18dp" android:layout_height="18dp" android:layout_margin="2dp" android:background="@drawable/led_off" />
                    <View android:id="@+id/led8" android:layout_width="18dp" android:layout_height="18dp" android:layout_margin="2dp" android:background="@drawable/led_off" />
                    <View android:id="@+id/led9" android:layout_width="18dp" android:layout_height="18dp" android:layout_margin="2dp" android:background="@drawable/led_off" />
                    <View android:id="@+id/led10" android:layout_width="18dp" android:layout_height="18dp" android:layout_margin="2dp" android:background="@drawable/led_off" />
                    <View android:id="@+id/led11" android:layout_width="18dp" android:layout_height="18dp" android:layout_margin="2dp" android:background="@drawable/led_off" />
                </LinearLayout>

                <!-- Scale Labels -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="0"
                        android:textColor="#4488FF"
                        android:textSize="10sp"
                        android:fontFamily="monospace"
                        android:gravity="start" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="DEFENSIVE"
                        android:textColor="#4488FF"
                        android:textSize="9sp"
                        android:fontFamily="monospace"
                        android:gravity="start" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="NORMAL"
                        android:textColor="#00FF88"
                        android:textSize="9sp"
                        android:fontFamily="monospace"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="AGGRESSIVE"
                        android:textColor="#FF6644"
                        android:textSize="9sp"
                        android:fontFamily="monospace"
                        android:gravity="end" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="11"
                        android:textColor="#FF4444"
                        android:textSize="10sp"
                        android:fontFamily="monospace"
                        android:gravity="end" />
                </LinearLayout>

                <!-- SeekBar Knob -->
                <SeekBar
                    android:id="@+id/knobSeekBar"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:max="11"
                    android:progress="5"
                    android:progressTint="#00FF88"
                    android:thumbTint="#00FF88"
                    android:layout_marginTop="8dp" />

                <!-- Current Mode Display -->
                <TextView
                    android:id="@+id/tvCurrentMode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="NORMAL"
                    android:textColor="#00FF88"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:layout_marginTop="16dp" />

                <!-- Mode Description -->
                <TextView
                    android:id="@+id/tvModeDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Balanced buying and selling behavior"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:layout_marginTop="4dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Behavior Stats Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#1A1A1A"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="BEHAVIOR METRICS"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="12dp" />

                <!-- Stats Grid -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Left Column -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Streak"
                            android:textColor="#666666"
                            android:textSize="10sp" />
                        <TextView
                            android:id="@+id/tvStreak"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Discipline"
                            android:textColor="#666666"
                            android:textSize="10sp" />
                        <TextView
                            android:id="@+id/tvDiscipline"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="50%"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="10X Runs"
                            android:textColor="#666666"
                            android:textSize="10sp" />
                        <TextView
                            android:id="@+id/tvTenX"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#FFD700"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Right Column -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Tilt Level"
                            android:textColor="#666666"
                            android:textSize="10sp" />
                        <TextView
                            android:id="@+id/tvTilt"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Sentiment"
                            android:textColor="#666666"
                            android:textSize="10sp" />
                        <TextView
                            android:id="@+id/tvSentiment"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="NEUTRAL"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="100X Moonshots"
                            android:textColor="#666666"
                            android:textSize="10sp" />
                        <TextView
                            android:id="@+id/tvHundredX"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#FF00FF"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Session Stats Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#1A1A1A"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SESSION STATS"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tvSessionTrades"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#FFFFFF"
                            android:textSize="24sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Trades"
                            android:textColor="#666666"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tvSessionWins"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#00FF88"
                            android:textSize="24sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Wins"
                            android:textColor="#666666"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tvSessionLosses"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#FF4444"
                            android:textSize="24sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Losses"
                            android:textColor="#666666"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tvSessionBigWins"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#FFD700"
                            android:textSize="24sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Big Wins"
                            android:textColor="#666666"
                            android:textSize="10sp" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Fluid Adjustment Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#1A1A1A"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="FLUID LEARNING IMPACT"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvFluidAdjustment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0.00"
                    android:textColor="#00FF88"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/tvFluidDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Neutral - thresholds unchanged"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:layout_marginTop="4dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Brain Health Dashboard Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#0A0A0A"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="NEURAL NETWORK STATUS"
                        android:textColor="#00FF88"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/tvCurriculumLevel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FRESHMAN"
                        android:textColor="#FFD700"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:background="#20FFD700"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="2dp" />

                </LinearLayout>

                <!-- Brain Network Visualization -->
                <com.lifecyclebot.ui.BrainNetworkView
                    android:id="@+id/brainNetworkView"
                    android:layout_width="match_parent"
                    android:layout_height="280dp"
                    android:layout_marginVertical="8dp" />

                <!-- Maturity Progress Bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MATURITY"
                            android:textColor="#666666"
                            android:textSize="10sp"
                            android:letterSpacing="0.1" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <TextView
                            android:id="@+id/tvMaturityPct"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textColor="#00FF88"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace" />

                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progressMaturity"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="4dp"
                        style="@android:style/Widget.ProgressBar.Horizontal"
                        android:progressDrawable="@drawable/progress_brain_maturity"
                        android:max="100"
                        android:progress="0" />

                </LinearLayout>

                <!-- Layer Status Grid -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp"
                    android:gravity="center">

                    <!-- Active Layers -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#10FFFFFF"
                        android:padding="12dp">
                        
                        <TextView
                            android:id="@+id/tvActiveLayers"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#00FF88"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ACTIVE"
                            android:textColor="#00FF88"
                            android:textSize="9sp"
                            android:letterSpacing="0.1" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="#20FFFFFF" />

                    <!-- Dormant Layers -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#10FFFFFF"
                        android:padding="12dp">
                        
                        <TextView
                            android:id="@+id/tvDormantLayers"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#FF8800"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DORMANT"
                            android:textColor="#FF8800"
                            android:textSize="9sp"
                            android:letterSpacing="0.1" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="#20FFFFFF" />

                    <!-- Average Accuracy -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#10FFFFFF"
                        android:padding="12dp">
                        
                        <TextView
                            android:id="@+id/tvAvgAccuracy"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="50%"
                            android:textColor="#FFFFFF"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ACCURACY"
                            android:textColor="#888888"
                            android:textSize="9sp"
                            android:letterSpacing="0.1" />
                    </LinearLayout>

                </LinearLayout>

                <!-- Top Performers & Warnings -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="12dp"
                    android:background="#08FFFFFF"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="TOP PERFORMING LAYERS"
                        android:textColor="#666666"
                        android:textSize="9sp"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tvTopLayers"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Awaiting data..."
                        android:textColor="#00FF88"
                        android:textSize="10sp"
                        android:fontFamily="monospace"
                        android:lineSpacingExtra="2dp" />

                    <!-- Dormant Warning (hidden by default) -->
                    <TextView
                        android:id="@+id/tvDormantWarning"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#FF8800"
                        android:textSize="9sp"
                        android:layout_marginTop="8dp"
                        android:visibility="gone"
                        android:drawablePadding="4dp" />

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Reset Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp">
            
            <Button
                android:id="@+id/btnResetLearning"
