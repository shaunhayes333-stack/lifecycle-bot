<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#000000"
    android:padding="24dp"
    android:fitsSystemWindows="true">

    <!-- Logo + glow container -->
    <FrameLayout
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_marginBottom="20dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/splash_glow"
            android:alpha="0.35"/>

        <ImageView
            android:id="@+id/ivSecurityLogo"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="center"
            android:src="@drawable/logo"
            android:scaleType="fitCenter"
            android:contentDescription="AATE Logo"/>
    </FrameLayout>

    <!-- Title -->
    <TextView
        android:id="@+id/tvSecurityTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Unlock AATE"
        android:textColor="#FFFFFF"
        android:textSize="26sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:letterSpacing="0.04"
        android:layout_marginBottom="6dp"/>

    <!-- Subtitle -->
    <TextView
        android:id="@+id/tvSecuritySubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter your PIN to access your wallet"
        android:textColor="#64D2D2"
        android:textSize="12sp"
        android:textAlignment="center"
        android:fontFamily="monospace"
        android:layout_marginBottom="20dp"/>

    <!-- Divider accent -->
    <View
        android:layout_width="40dp"
        android:layout_height="1dp"
        android:background="#14F195"
        android:alpha="0.5"
        android:layout_marginBottom="20dp"/>

    <!-- Error message -->
    <TextView
        android:id="@+id/tvSecurityError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#EF4444"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:visibility="gone"
        android:layout_marginBottom="12dp"/>

    <!-- PIN entry container -->
    <LinearLayout
        android:id="@+id/layoutSecurityPin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="visible">

        <!-- PIN input -->
        <EditText
            android:id="@+id/etSecurityPin"
            android:layout_width="220dp"
            android:layout_height="@dimen/input_height"
            android:background="@drawable/edit_text_bg"
            android:hint="Enter PIN"
            android:textColorHint="#4B5563"
            android:textColor="#14F195"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:letterSpacing="0.4"
            android:inputType="numberPassword"
            android:maxLength="6"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:fontFamily="monospace"
            android:layout_marginBottom="16dp"/>

        <!-- Unlock button -->
        <Button
            android:id="@+id/btnSecuritySubmit"
            android:layout_width="220dp"
            android:layout_height="50dp"
            android:text="Unlock"
            android:textColor="#000000"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:background="@drawable/button_primary_bg"
            android:layout_marginBottom="12dp"/>

    </LinearLayout>

    <!-- Biometric button -->
    <Button
        android:id="@+id/btnSecurityBiometric"
        android:layout_width="220dp"
        android:layout_height="44dp"
        android:text="Use Fingerprint"
        android:textColor="#64D2D2"
        android:textSize="12sp"
        android:textAllCaps="false"
        android:background="@android:color/transparent"
        android:visibility="gone"
        android:drawableStart="@android:drawable/ic_menu_compass"
        android:drawablePadding="8dp"/>

    <!-- Security disclaimer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="28dp"
        android:background="@drawable/section_card_bg"
        android:padding="14dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠ IMPORTANT"
            android:textColor="#F59E0B"
            android:textSize="10sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:letterSpacing="0.1"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Store your PIN in a safe place. AATE cannot recover lost PINs or access locked funds. You are solely responsible for securing your wallet credentials."
            android:textColor="#4B5563"
            android:textSize="9sp"
            android:textAlignment="center"
            android:fontFamily="monospace"
            android:lineSpacingMultiplier="1.4"/>

    </LinearLayout>

    <!-- Version badge -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AATE v5.0"
            android:textColor="#64D2D2"
            android:textSize="12sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:letterSpacing="0.1"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Autonomous AI Trading Engine"
            android:textColor="#1F2937"
            android:textSize="8sp"
            android:fontFamily="monospace"/>

    </LinearLayout>

</LinearLayout>
