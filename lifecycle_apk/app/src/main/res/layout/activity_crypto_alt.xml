<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- TOP BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/topbar_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/screen_padding"
        android:paddingEnd="@dimen/screen_padding"
        android:background="#0A0A0F">

        <TextView
            android:id="@+id/btnCryptoAltBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&#8592;"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:paddingEnd="12dp"
            android:clickable="true"
            android:focusable="true"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#127760; Crypto Alts"
                    android:textColor="#A78BFA"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
                <View
                    android:layout_width="5dp"
                    android:layout_height="5dp"
                    android:layout_marginStart="6dp"
                    android:layout_marginBottom="1dp"
                    android:background="@drawable/dot_green"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvCryptoAltStats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BNB &#183; ETH &#183; SOL &#183; Polygon"
                android:textColor="#4B5563"
                android:textSize="9sp"
                android:fontFamily="monospace"/>
        </LinearLayout>

        <!-- Scan button -->
        <TextView
            android:id="@+id/btnCryptoAltScan"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:gravity="center"
            android:text="&#8635; Scan"
            android:textColor="#A78BFA"
            android:textSize="11sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/pill_bg"
            android:clickable="true"
            android:focusable="true"/>

        <!-- Add button -->
        <TextView
            android:id="@+id/btnCryptoAltAdd"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:gravity="center"
            android:text="+ Add"
            android:textColor="#000000"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/pill_bg_yellow"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

    <!-- TABS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:paddingStart="@dimen/screen_padding"
        android:paddingEnd="@dimen/screen_padding"
        android:background="#0D0D14">

        <TextView
            android:id="@+id/tabCryptoAltScanner"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="&#128269; Scanner"
            android:textColor="#A78BFA"
            android:textSize="11sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/tabCryptoAltWatchlist"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="&#11088; Watchlist"
            android:textColor="#6B7280"
            android:textSize="11sp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/tabCryptoAltPositions"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="&#128194; Positions"
            android:textColor="#6B7280"
            android:textSize="11sp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/tabCryptoAltSettings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="&#9881;&#65039; Settings"
            android:textColor="#6B7280"
            android:textSize="11sp"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

    <!-- PROGRESS -->
    <ProgressBar
        android:id="@+id/progressCryptoAlt"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        style="?android:attr/progressBarStyleHorizontal"
        android:indeterminate="true"
        android:indeterminateTint="#A78BFA"
        android:visibility="gone"/>

    <!-- SCROLLABLE CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/llCryptoAltContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp"/>

    </ScrollView>

</LinearLayout>
